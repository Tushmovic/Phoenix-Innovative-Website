<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
    <style>
        .page-hero {
            background: linear-gradient(135deg, #FF6B35, #F25F3A, #E71D36);
            color: white;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }
        
        .page-hero h1 {
            color: white;
            font-size: 3.5rem;
            font-weight: 800;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        .page-hero p {
            color: rgba(255,255,255,0.95);
            font-size: 1.3rem;
        }
        
        .about-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin: 50px 0;
        }
        
        .about-card {
            background: white;
            border-radius: 20px;
            padding: 40px 30px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-align: center;
            height: 100%;
            position: relative;
            overflow: hidden;
        }
        
        .about-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #FF6B35, #4361EE);
            transform: scaleX(0);
            transition: transform 0.4s ease;
        }
        
        .about-card:hover::before {
            transform: scaleX(1);
        }
        
        .about-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 30px 50px rgba(255,107,53,0.15);
        }
        
        .about-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #FF6B35, #4361EE);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            color: white;
            font-size: 32px;
            transition: all 0.4s ease;
        }
        
        .about-card:hover .about-icon {
            transform: rotateY(180deg) scale(1.1);
        }
        
        .about-card h3 {
            color: #333;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 15px;
        }
        
        .about-card p {
            color: #666;
            line-height: 1.6;
            margin-bottom: 25px;
        }
        
        .about-btn {
            display: inline-block;
            padding: 10px 25px;
            background: transparent;
            color: #FF6B35;
            text-decoration: none;
            border: 2px solid #FF6B35;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            z-index: 1;
        }
        
        .about-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, #FF6B35, #4361EE);
            transition: left 0.3s ease;
            z-index: -1;
        }
        
        .about-btn:hover::before {
            left: 0;
        }
        
        .about-btn:hover {
            color: white;
            border-color: transparent;
        }
        
        .mission-vision-section {
            background: linear-gradient(135deg, #f8f9fa, white);
            padding: 60px 0;
        }
        
        .mission-vision-card {
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            height: 100%;
            transition: all 0.3s ease;
            border-bottom: 4px solid transparent;
        }
        
        .mission-vision-card:hover {
            transform: translateY(-10px);
            border-bottom-color: #FF6B35;
        }
        
        .mission-vision-card h3 {
            color: #333;
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 20px;
        }
        
        .mission-vision-card p {
            color: #666;
            line-height: 1.8;
        }
        
        .stats-section {
            background: linear-gradient(135deg, #1C2541, #3A506B);
            padding: 60px 0;
        }
        
        .stat-item {
            text-align: center;
            color: white;
        }
        
        .stat-number {
            font-size: 3rem;
            font-weight: 800;
            color: #FF6B35;
            margin-bottom: 10px;
        }
        
        .stat-label {
            color: rgba(255,255,255,0.9);
            font-size: 1.1rem;
        }
        
        .cta-section {
            background: linear-gradient(135deg, #4361EE, #2EC4B6);
            color: white;
            padding: 80px 0;
        }
        
        .cta-section h2 {
            color: white;
            font-size: 2.8rem;
            font-weight: 800;
        }
        
        .cta-section p {
            color: rgba(255,255,255,0.95);
        }
        
        .cta-section .btn-light {
            background: white;
            color: #333;
            border: none;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 50px;
        }
        
        .cta-section .btn-outline-light {
            background: transparent;
            border: 2px solid white;
            color: white;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 50px;
        }
        
        .cta-section .btn-outline-light:hover {
            background: white;
            color: #333;
        }
        
        @media (max-width: 768px) {
            .page-hero h1 {
                font-size: 2.5rem;
            }
            
            .about-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <%- include('partials/header'); %>
    <%- include('partials/floating-buttons'); %>

    <!-- Hero Section -->
    <section class="page-hero">
        <div class="container text-center">
            <h1 data-aos="fade-up">About Phoenix</h1>
            <p class="lead" data-aos="fade-up" data-aos-delay="100">Building intelligent systems for a smarter world</p>
        </div>
    </section>

    <!-- About Grid -->
    <section class="py-5">
        <div class="container">
            <div class="about-grid">
                <!-- Company Overview -->
                <div class="about-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="about-icon">
                        <i class="bi bi-building"></i>
                    </div>
                    <h3>Company Overview</h3>
                    <p>Learn about our journey, mission, and the values that drive us forward as a leading technology solutions provider.</p>
                    <a href="/about/company" class="about-btn">Read More</a>
                </div>

                <!-- Mission & Vision -->
                <div class="about-card" data-aos="fade-up" data-aos-delay="200">
                    <div class="about-icon">
                        <i class="bi bi-bullseye"></i>
                    </div>
                    <h3>Mission & Vision</h3>
                    <p>Discover our purpose and where we're headed as Africa's leading technology partner for digital transformation.</p>
                    <a href="/about/mission" class="about-btn">Read More</a>
                </div>

                <!-- Our Values -->
                <div class="about-card" data-aos="fade-up" data-aos-delay="300">
                    <div class="about-icon">
                        <i class="bi bi-star"></i>
                    </div>
                    <h3>Our Values</h3>
                    <p>The principles that guide everything we do at Phoenix, from integrity to innovation and customer success.</p>
                    <a href="/about/values" class="about-btn">Read More</a>
                </div>

                <!-- Our Team -->
                <div class="about-card" data-aos="fade-up" data-aos-delay="400">
                    <div class="about-icon">
                        <i class="bi bi-people"></i>
                    </div>
                    <h3>Our Team</h3>
                    <p>Meet the brilliant minds behind our innovative solutions – experienced professionals passionate about technology.</p>
                    <a href="/about/team" class="about-btn">Meet the Team</a>
                </div>

                <!-- Certifications -->
                <div class="about-card" data-aos="fade-up" data-aos-delay="500">
                    <div class="about-icon">
                        <i class="bi bi-award"></i>
                    </div>
                    <h3>Certifications</h3>
                    <p>Our industry certifications and technology partnerships with global leaders like Microsoft, Cisco, and Huawei.</p>
                    <a href="/about/certifications" class="about-btn">View Certifications</a>
                </div>

                <!-- Careers -->
                <div class="about-card" data-aos="fade-up" data-aos-delay="600">
                    <div class="about-icon">
                        <i class="bi bi-briefcase"></i>
                    </div>
                    <h3>Careers</h3>
                    <p>Join our team and build your career at the forefront of technology innovation in Africa.</p>
                    <a href="/about/careers" class="about-btn">View Openings</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Mission & Vision Highlight -->
    <section class="mission-vision-section">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-6" data-aos="fade-right">
                    <div class="mission-vision-card">
                        <h3>Our Mission</h3>
                        <p>To empower businesses and communities across Africa with innovative technology solutions that drive growth, efficiency, and sustainable development in the digital age.</p>
                    </div>
                </div>
                <div class="col-md-6" data-aos="fade-left">
                    <div class="mission-vision-card">
                        <h3>Our Vision</h3>
                        <p>To be Africa's most trusted technology partner, recognized for excellence, innovation, and lasting impact on the continent's digital transformation.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="100">
                    <div class="stat-item">
                        <div class="stat-number">500+</div>
                        <div class="stat-label">Projects Completed</div>
                    </div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="200">
                    <div class="stat-item">
                        <div class="stat-number">50+</div>
                        <div class="stat-label">Team Members</div>
                    </div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="300">
                    <div class="stat-item">
                        <div class="stat-number">9</div>
                        <div class="stat-label">Countries Served</div>
                    </div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="400">
                    <div class="stat-item">
                        <div class="stat-number">10+</div>
                        <div class="stat-label">Years Experience</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8">
                    <h2 data-aos="fade-up">Ready to Work With Us?</h2>
                    <p class="lead mb-5" data-aos="fade-up" data-aos-delay="100">Let's discuss how we can help transform your business with technology</p>
                    <div class="d-flex justify-content-center gap-3" data-aos="fade-up" data-aos-delay="200">
                        <a href="/contact" class="btn btn-light btn-lg px-5 py-3">Contact Us</a>
                        <a href="/about/careers" class="btn btn-outline-light btn-lg px-5 py-3">Join Our Team</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('partials/footer'); %>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="/js/animations.js"></script>
    <script src="/js/transitions.js"></script>
    <script>
        AOS.init({
            duration: 1000,
            once: true,
            offset: 100
        });
    </script>
</body>
</html>