<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
    <style>
        .page-hero {
            background: linear-gradient(135deg, #0B132B, #1C2541, #3A506B);
            color: white;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }
        
        .timeline {
            position: relative;
            padding: 40px 0;
        }
        
        .timeline::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            width: 2px;
            height: 100%;
            background: linear-gradient(180deg, #FF6B35, #4361EE);
            transform: translateX(-50%);
        }
        
        .timeline-item {
            position: relative;
            margin-bottom: 60px;
            width: 50%;
        }
        
        .timeline-item:nth-child(odd) {
            left: 0;
            padding-right: 40px;
        }
        
        .timeline-item:nth-child(even) {
            left: 50%;
            padding-left: 40px;
        }
        
        .timeline-content {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            position: relative;
        }
        
        .timeline-content::before {
            content: '';
            position: absolute;
            top: 20px;
            width: 20px;
            height: 20px;
            background: #FF6B35;
            border-radius: 50%;
        }
        
        .timeline-item:nth-child(odd) .timeline-content::before {
            right: -50px;
        }
        
        .timeline-item:nth-child(even) .timeline-content::before {
            left: -50px;
        }
        
        .timeline-year {
            display: inline-block;
            padding: 5px 20px;
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            color: white;
            border-radius: 25px;
            font-weight: bold;
            margin-bottom: 15px;
        }
        
        .value-card {
            background: white;
            padding: 40px 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            text-align: center;
            transition: all 0.3s ease;
            height: 100%;
        }
        
        .value-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 30px 50px rgba(255,107,53,0.2);
        }
        
        .value-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            color: white;
            font-size: 32px;
        }
        
        .stats-card {
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            color: white;
            padding: 40px 20px;
            border-radius: 15px;
            text-align: center;
            transition: all 0.3s ease;
        }
        
        .stats-card:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 20px 40px rgba(255,107,53,0.3);
        }
        
        .milestone-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            height: 100%;
            transition: all 0.3s ease;
            border-left: 4px solid #FF6B35;
        }
        
        .milestone-card:hover {
            transform: translateX(10px);
            box-shadow: 0 20px 40px rgba(255,107,53,0.15);
        }
        
        .cta-section {
            background: linear-gradient(135deg, #1C2541, #3A506B);
            color: white;
            padding: 80px 0;
        }
    </style>
</head>
<body>
    <%- include('../partials/header'); %>
    <%- include('../partials/floating-buttons'); %>

    <!-- Hero Section -->
    <section class="page-hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8 mx-auto text-center" data-aos="fade-up">
                    <h1 class="display-3 fw-bold mb-4">Company Overview</h1>
                    <p class="lead mb-4">Building intelligent systems for a smarter world since 2015</p>
                </div>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section class="py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6" data-aos="fade-right">
                    <h2 class="display-5 fw-bold mb-4">Who We Are</h2>
                    <p class="lead mb-4">Phoenix Innovative Technologies is a leading technology solutions provider dedicated to empowering businesses across Africa with cutting-edge digital infrastructure and intelligent systems.</p>
                    <p class="mb-4">Founded in 2015, we have grown from a small team of passionate engineers to a comprehensive technology partner serving clients across various industries including banking, telecommunications, healthcare, education, and government.</p>
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-4"></i>
                                <span>ISO 9001 Certified</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-4"></i>
                                <span>Microsoft Partner</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-4"></i>
                                <span>Cisco Partner</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-4"></i>
                                <span>Huawei Certified</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6" data-aos="fade-left">
                    <img src="/images/about/company.jpg" alt="Phoenix Team" class="img-fluid rounded-3 shadow">
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="100">
                    <div class="stats-card">
                        <div class="display-4 fw-bold counter-value" data-target="9">0</div>
                        <p class="mb-0">Years of Excellence</p>
                    </div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="200">
                    <div class="stats-card" style="background: linear-gradient(135deg, #4361EE, #3A0CA3);">
                        <div class="display-4 fw-bold counter-value" data-target="500">0</div>
                        <p class="mb-0">Projects Completed</p>
                    </div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="300">
                    <div class="stats-card" style="background: linear-gradient(135deg, #2EC4B6, #4361EE);">
                        <div class="display-4 fw-bold counter-value" data-target="50">0</div>
                        <p class="mb-0">Team Members</p>
                    </div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="400">
                    <div class="stats-card" style="background: linear-gradient(135deg, #FF9F1C, #FF6B35);">
                        <div class="display-4 fw-bold counter-value" data-target="100">0</div>
                        <p class="mb-0">Happy Clients</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Timeline Section -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">Our Journey</h2>
            <div class="timeline">
                <div class="timeline-item" data-aos="fade-right">
                    <div class="timeline-content">
                        <span class="timeline-year">2015</span>
                        <h4 class="fw-bold">Company Founded</h4>
                        <p>Phoenix Innovative Technologies established in Abuja, Nigeria with a vision to transform Africa's technology landscape.</p>
                    </div>
                </div>
                <div class="timeline-item" data-aos="fade-left">
                    <div class="timeline-content">
                        <span class="timeline-year">2017</span>
                        <h4 class="fw-bold">First Major Contract</h4>
                        <p>Secured our first enterprise client, implementing network infrastructure for a leading bank.</p>
                    </div>
                </div>
                <div class="timeline-item" data-aos="fade-right">
                    <div class="timeline-content">
                        <span class="timeline-year">2019</span>
                        <h4 class="fw-bold">Expansion to Lagos</h4>
                        <p>Opened Lagos office to serve clients in Nigeria's commercial capital.</p>
                    </div>
                </div>
                <div class="timeline-item" data-aos="fade-left">
                    <div class="timeline-content">
                        <span class="timeline-year">2021</span>
                        <h4 class="fw-bold">ISO 9001 Certification</h4>
                        <p>Achieved ISO 9001:2015 certification for quality management systems.</p>
                    </div>
                </div>
                <div class="timeline-item" data-aos="fade-right">
                    <div class="timeline-content">
                        <span class="timeline-year">2023</span>
                        <h4 class="fw-bold">500 Projects Milestone</h4>
                        <p>Celebrated completing 500 successful projects across various industries.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Values Section -->
    <section class="py-5 bg-light">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">Our Core Values</h2>
            <div class="row g-4">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="value-card">
                        <div class="value-icon">
                            <i class="bi bi-star"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Excellence</h4>
                        <p class="text-muted">We strive for excellence in everything we do, delivering solutions that exceed expectations.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="value-card">
                        <div class="value-icon">
                            <i class="bi bi-lightbulb"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Innovation</h4>
                        <p class="text-muted">We embrace innovation and continuously explore new technologies to solve complex challenges.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="value-card">
                        <div class="value-icon">
                            <i class="bi bi-people"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Integrity</h4>
                        <p class="text-muted">We operate with transparency, honesty, and integrity in all our relationships.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8">
                    <h2 class="display-4 fw-bold mb-4" data-aos="fade-up">Join Us on Our Journey</h2>
                    <p class="lead mb-5" data-aos="fade-up" data-aos-delay="100">Be part of Africa's technology revolution</p>
                    <div class="d-flex justify-content-center gap-3" data-aos="fade-up" data-aos-delay="200">
                        <a href="/contact" class="btn btn-light btn-lg px-5 py-3">Contact Us</a>
                        <a href="/about/careers" class="btn btn-outline-light btn-lg px-5 py-3">Join Our Team</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('../partials/footer'); %>

    <script>
        AOS.init({
            duration: 1000,
            once: true,
            offset: 100
        });

        // Counter animation
        function animateCounter(element, target) {
            let current = 0;
            const increment = target / 50;
            const timer = setInterval(() => {
                current += increment;
                if (current >= target) {
                    element.textContent = target;
                    clearInterval(timer);
                } else {
                    element.textContent = Math.floor(current);
                }
            }, 20);
        }

        const counters = document.querySelectorAll('.counter-value');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const target = parseFloat(entry.target.dataset.target);
                    animateCounter(entry.target, target);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        counters.forEach(counter => observer.observe(counter));
    </script>
</body>
</html>