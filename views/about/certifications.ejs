<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
    <style>
        /* Hero Section */
        .page-hero {
            background: linear-gradient(135deg, #2EC4B6, #4361EE, #3A0CA3);
            color: white;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }

        .page-hero h1 {
            color: white !important;
            font-size: 3.5rem;
            font-weight: 800;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .page-hero p {
            color: rgba(255,255,255,0.95) !important;
            font-size: 1.4rem;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Stats Cards */
        .stats-card {
            background: linear-gradient(135deg, #2EC4B6, #4361EE);
            color: white;
            padding: 40px 20px;
            border-radius: 15px;
            text-align: center;
            transition: all 0.3s ease;
        }

        .stats-card:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 20px 40px rgba(46,196,182,0.3);
        }

        .stats-number {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 10px;
            color: white !important;
        }

        .stats-card p {
            color: rgba(255,255,255,0.95) !important;
            font-size: 1.1rem;
        }

        /* Cert Cards */
        .cert-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin: 50px 0;
        }

        .cert-card {
            background: white;
            border-radius: 20px;
            padding: 40px 30px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            text-align: center;
            position: relative;
            overflow: hidden;
            border: 2px solid transparent;
        }

        .cert-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #2EC4B6, #4361EE);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }

        .cert-card:hover {
            transform: translateY(-15px);
            border-color: #2EC4B6;
            box-shadow: 0 30px 50px rgba(46,196,182,0.15);
        }

        .cert-card:hover::before {
            transform: scaleX(1);
        }

        .cert-logo {
            height: 100px;
            margin-bottom: 25px;
            filter: grayscale(100%);
            opacity: 0.7;
            transition: all 0.3s ease;
        }

        .cert-card:hover .cert-logo {
            filter: grayscale(0);
            opacity: 1;
            transform: scale(1.1);
        }

        .cert-name {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 10px;
            color: #333 !important;
        }

        .cert-issuer {
            color: #2EC4B6 !important;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .cert-card p {
            color: #666 !important;
        }

        .cert-badge {
            display: inline-block;
            padding: 5px 20px;
            background: linear-gradient(135deg, #2EC4B6, #4361EE);
            color: white !important;
            border-radius: 25px;
            font-size: 12px;
            font-weight: 600;
        }

        /* Partner Cards */
        .partner-card {
            background: white;
            padding: 40px 30px;
            border-radius: 20px;
            height: 100%;
            transition: all 0.3s ease;
            text-align: center;
            border: 1px solid #e9ecef;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        .partner-card:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 20px 40px rgba(46,196,182,0.15);
            border-color: #2EC4B6;
        }

        .partner-logo {
            height: 80px;
            margin-bottom: 20px;
            filter: grayscale(100%);
            transition: all 0.3s ease;
        }

        .partner-card:hover .partner-logo {
            filter: grayscale(0);
        }

        .partner-card h4 {
            color: #333 !important;
            font-size: 1.3rem;
            font-weight: 700;
            margin: 15px 0 10px;
        }

        .partner-level {
            display: inline-block;
            padding: 5px 15px;
            background: #FFD700;
            color: #333 !important;
            border-radius: 15px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .partner-level.gold {
            background: #FFD700;
        }

        .partner-level.silver {
            background: #C0C0C0;
        }

        .partner-level.platinum {
            background: #E5E4E2;
        }

        .partner-card p {
            color: #666 !important;
        }

        /* Cert Showcase */
        .cert-showcase {
            background: white;
            padding: 60px 40px;
            border-radius: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        .cert-showcase h4 {
            color: #2EC4B6 !important;
            font-size: 2rem;
            font-weight: 800;
        }

        .cert-showcase p {
            color: #333 !important;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .cert-showcase small {
            color: #666 !important;
        }

        /* Expertise Badges */
        .expertise-badge {
            display: inline-block;
            padding: 8px 20px;
            background: white;
            border-radius: 50px;
            margin: 5px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            border: 1px solid #e9ecef;
            transition: all 0.3s ease;
            color: #333 !important;
            font-weight: 500;
        }

        .expertise-badge:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(46,196,182,0.15);
            border-color: #2EC4B6;
            color: #2EC4B6 !important;
        }

        /* Timeline Cards */
        .timeline-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            margin-bottom: 20px;
            border-left: 4px solid #2EC4B6;
            transition: all 0.3s ease;
        }

        .timeline-card:hover {
            transform: translateX(10px);
            box-shadow: 0 20px 40px rgba(46,196,182,0.15);
        }

        .cert-year {
            font-size: 2rem;
            font-weight: 800;
            color: #2EC4B6 !important;
            margin-bottom: 10px;
        }

        .timeline-card h4 {
            color: #333 !important;
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .timeline-card p {
            color: #666 !important;
        }

        /* CTA Section */
        .cta-section {
            background: linear-gradient(135deg, #2EC4B6, #4361EE);
            color: white;
            padding: 80px 0;
        }

        .cta-section h2,
        .cta-section p,
        .cta-section .lead {
            color: white !important;
        }

        .cta-section .btn-light {
            background: white;
            color: #333 !important;
            border: none;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 8px;
        }

        .cta-section .btn-outline-light {
            background: transparent;
            border: 2px solid white;
            color: white !important;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 8px;
        }

        .cta-section .btn-outline-light:hover {
            background: white;
            color: #333 !important;
        }

        /* Section Headers */
        h2.display-5 {
            color: #333 !important;
            font-size: 2.8rem;
            font-weight: 800;
            margin-bottom: 3rem;
        }

        .bg-light {
            background-color: #f8f9fa !important;
        }

        .text-muted {
            color: #666 !important;
        }

        @media (max-width: 768px) {
            .page-hero h1 {
                font-size: 2.5rem;
            }

            h2.display-5 {
                font-size: 2.2rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/header'); %>
    <%- include('../partials/floating-buttons'); %>

    <!-- Hero Section -->
    <section class="page-hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8 mx-auto text-center" data-aos="fade-up">
                    <h1 class="display-3 fw-bold mb-4">Certifications & Partnerships</h1>
                    <p class="lead mb-4">Recognized excellence through industry-leading certifications</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="100">
                    <div class="stats-card">
                        <div class="stats-number counter-value" data-target="25">0</div>
                        <p class="mb-0">Active Certifications</p>
                    </div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="200">
                    <div class="stats-card" style="background: linear-gradient(135deg, #4361EE, #3A0CA3);">
                        <div class="stats-number counter-value" data-target="15">0</div>
                        <p class="mb-0">Technology Partners</p>
                    </div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="300">
                    <div class="stats-card" style="background: linear-gradient(135deg, #FF9F1C, #FF6B35);">
                        <div class="stats-number counter-value" data-target="50">0</div>
                        <p class="mb-0">Certified Engineers</p>
                    </div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="400">
                    <div class="stats-card" style="background: linear-gradient(135deg, #3A0CA3, #4361EE);">
                        <div class="stats-number counter-value" data-target="8">0</div>
                        <p class="mb-0">Years ISO Certified</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ISO Certifications -->
    <section class="py-5 bg-light">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">ISO Certifications</h2>
            <div class="cert-grid">
                <!-- ISO 9001 -->
                <div class="cert-card" data-aos="fade-up" data-aos-delay="100">
                    <img src="/images/certs/iso-9001.png" alt="ISO 9001" class="cert-logo">
                    <h3 class="cert-name">ISO 9001:2015</h3>
                    <div class="cert-issuer">Quality Management Systems</div>
                    <p class="text-muted mb-3">Certified for excellence in quality management and continuous improvement processes.</p>
                    <span class="cert-badge">Since 2017</span>
                </div>

                <!-- ISO 27001 -->
                <div class="cert-card" data-aos="fade-up" data-aos-delay="200">
                    <img src="/images/certs/iso-27001.png" alt="ISO 27001" class="cert-logo">
                    <h3 class="cert-name">ISO 27001:2022</h3>
                    <div class="cert-issuer">Information Security Management</div>
                    <p class="text-muted mb-3">Demonstrating our commitment to information security and data protection.</p>
                    <span class="cert-badge">Since 2019</span>
                </div>

                <!-- ISO 14001 -->
                <div class="cert-card" data-aos="fade-up" data-aos-delay="300">
                    <img src="/images/certs/iso-14001.png" alt="ISO 14001" class="cert-logo">
                    <h3 class="cert-name">ISO 14001:2015</h3>
                    <div class="cert-issuer">Environmental Management</div>
                    <p class="text-muted mb-3">Certified for our commitment to environmental responsibility and sustainability.</p>
                    <span class="cert-badge">Since 2020</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Technology Partners -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">Technology Partners</h2>
            <div class="row g-4">
                <!-- Microsoft -->
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="partner-card">
                        <img src="/images/partners/microsoft.png" alt="Microsoft" class="partner-logo">
                        <h4 class="fw-bold mt-3">Microsoft</h4>
                        <span class="partner-level gold">Gold Partner</span>
                        <p class="text-muted mt-3">Specializations in Azure, Security, and Modern Work</p>
                    </div>
                </div>

                <!-- Cisco -->
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="partner-card">
                        <img src="/images/partners/cisco.png" alt="Cisco" class="partner-logo">
                        <h4 class="fw-bold mt-3">Cisco</h4>
                        <span class="partner-level platinum">Platinum Partner</span>
                        <p class="text-muted mt-3">Certified in Networking, Security, and Collaboration</p>
                    </div>
                </div>

                <!-- Huawei -->
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="partner-card">
                        <img src="/images/partners/huawei.png" alt="Huawei" class="partner-logo">
                        <h4 class="fw-bold mt-3">Huawei</h4>
                        <span class="partner-level gold">Gold Partner</span>
                        <p class="text-muted mt-3">Enterprise Networking and Cybersecurity Solutions</p>
                    </div>
                </div>

                <!-- AWS -->
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="400">
                    <div class="partner-card">
                        <img src="/images/partners/aws.png" alt="AWS" class="partner-logo">
                        <h4 class="fw-bold mt-3">Amazon Web Services</h4>
                        <span class="partner-level">Advanced Partner</span>
                        <p class="text-muted mt-3">Cloud Migration and Managed Services</p>
                    </div>
                </div>

                <!-- Fortinet -->
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="500">
                    <div class="partner-card">
                        <img src="/images/partners/fortinet.png" alt="Fortinet" class="partner-logo">
                        <h4 class="fw-bold mt-3">Fortinet</h4>
                        <span class="partner-level gold">Gold Partner</span>
                        <p class="text-muted mt-3">Network Security Expertise</p>
                    </div>
                </div>

                <!-- VMware -->
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="600">
                    <div class="partner-card">
                        <img src="/images/partners/vmware.png" alt="VMware" class="partner-logo">
                        <h4 class="fw-bold mt-3">VMware</h4>
                        <span class="partner-level">Enterprise Partner</span>
                        <p class="text-muted mt-3">Virtualization and Cloud Infrastructure</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Professional Certifications -->
    <section class="py-5 bg-light">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">Team Certifications</h2>
            <div class="row">
                <div class="col-lg-8 mx-auto">
                    <div class="cert-showcase" data-aos="fade-up">
                        <div class="row text-center">
                            <div class="col-md-4 mb-4">
                                <h4 class="fw-bold">50+</h4>
                                <p>Cisco Certified</p>
                                <small>CCNA, CCNP, CCIE</small>
                            </div>
                            <div class="col-md-4 mb-4">
                                <h4 class="fw-bold">30+</h4>
                                <p>Microsoft Certified</p>
                                <small>Azure, Security, M365</small>
                            </div>
                            <div class="col-md-4 mb-4">
                                <h4 class="fw-bold">20+</h4>
                                <p>Security Certifications</p>
                                <small>CISSP, CEH, CISM</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5" data-aos="fade-up">
                <span class="expertise-badge">CCNA</span>
                <span class="expertise-badge">CCNP</span>
                <span class="expertise-badge">CCIE</span>
                <span class="expertise-badge">Azure Administrator</span>
                <span class="expertise-badge">Azure Architect</span>
                <span class="expertise-badge">AWS Solutions Architect</span>
                <span class="expertise-badge">CISSP</span>
                <span class="expertise-badge">CEH</span>
                <span class="expertise-badge">PMP</span>
                <span class="expertise-badge">ITIL</span>
                <span class="expertise-badge">PRINCE2</span>
                <span class="expertise-badge">Fortinet NSE</span>
            </div>
        </div>
    </section>

    <!-- Certification Timeline -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">Our Certification Journey</h2>
            <div class="row">
                <div class="col-lg-8 mx-auto">
                    <div class="timeline-card" data-aos="fade-right">
                        <div class="cert-year">2017</div>
                        <h4 class="fw-bold">ISO 9001 Certification</h4>
                        <p>First ISO certification achieved for quality management systems.</p>
                    </div>
                    <div class="timeline-card" data-aos="fade-right">
                        <div class="cert-year">2018</div>
                        <h4 class="fw-bold">Microsoft Gold Partner</h4>
                        <p>Achieved Gold Partner status with Microsoft.</p>
                    </div>
                    <div class="timeline-card" data-aos="fade-right">
                        <div class="cert-year">2019</div>
                        <h4 class="fw-bold">ISO 27001 & Cisco Gold</h4>
                        <p>Information security certification and Cisco Gold partnership.</p>
                    </div>
                    <div class="timeline-card" data-aos="fade-right">
                        <div class="cert-year">2020</div>
                        <h4 class="fw-bold">ISO 14001 & AWS Partner</h4>
                        <p>Environmental management certification and AWS partnership.</p>
                    </div>
                    <div class="timeline-card" data-aos="fade-right">
                        <div class="cert-year">2021</div>
                        <h4 class="fw-bold">Huawei Gold Partner</h4>
                        <p>Expanded partnership with Huawei.</p>
                    </div>
                    <div class="timeline-card" data-aos="fade-right">
                        <div class="cert-year">2023</div>
                        <h4 class="fw-bold">Fortinet Gold Partner</h4>
                        <p>Achieved Gold status with Fortinet for security excellence.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8">
                    <h2 class="display-4 fw-bold mb-4" data-aos="fade-up">Trust Our Certified Expertise</h2>
                    <p class="lead mb-5" data-aos="fade-up" data-aos-delay="100">Work with certified professionals committed to excellence</p>
                    <div class="d-flex justify-content-center gap-3" data-aos="fade-up" data-aos-delay="200">
                        <a href="/contact" class="btn btn-light btn-lg px-5 py-3">Contact Us</a>
                        <a href="/services" class="btn btn-outline-light btn-lg px-5 py-3">Our Services</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('../partials/footer'); %>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="/js/animations.js"></script>
    <script src="/js/transitions.js"></script>
    <script>
        AOS.init({
            duration: 1000,
            once: true,
            offset: 100
        });

        function animateCounter(element, target) {
            let current = 0;
            const increment = target / 50;
            const timer = setInterval(() => {
                current += increment;
                if (current >= target) {
                    element.textContent = target;
                    clearInterval(timer);
                } else {
                    element.textContent = Math.floor(current);
                }
            }, 20);
        }

        const counters = document.querySelectorAll('.counter-value');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const target = parseFloat(entry.target.dataset.target);
                    animateCounter(entry.target, target);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        counters.forEach(counter => observer.observe(counter));
    </script>
</body>
</html>