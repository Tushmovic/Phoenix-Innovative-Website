    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="/js/animations.js"></script>
    <script src="/js/transitions.js"></script>
    <script>
        AOS.init({
            duration: 1000,
            once: true,
            offset: 100
        });

        function animateCounter(element, target) {
            let current = 0;
            const increment = target / 50;
            const timer = setInterval(() => {
                current += increment;
                if (current >= target) {
                    element.textContent = target;
                    clearInterval(timer);
                } else {
                    element.textContent = Math.floor(current);
                }
            }, 20);
        }

        const counters = document.querySelectorAll('.counter-value');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const target = parseFloat(entry.target.dataset.target);
                    animateCounter(entry.target, target);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        counters.forEach(counter => observer.observe(counter));

        function filterJobs() {
            const filter = document.getElementById('jobFilter').value;
            const jobs = document.querySelectorAll('.job-card');
            
            jobs.forEach(job => {
                if (filter === 'all' || job.dataset.department === filter) {
                    job.style.display = 'block';
                } else {
                    job.style.display = 'none';
                }
            });
        }

        function selectJob(position) {
            document.getElementById('appliedPosition').value = position;
            document.getElementById('apply').scrollIntoView({ behavior: 'smooth' });
        }

        function submitApplication(event) {
            event.preventDefault();
            alert('Thank you for your application! We will review it and get back to you soon.');
            event.target.reset();
        }

        document.querySelector('.upload-area').addEventListener('click', function() {
            document.getElementById('cvFile').click();
        });
        
        // Add touch feedback for upload area
        document.querySelector('.upload-area').addEventListener('touchstart', function() {
            this.style.backgroundColor = '#fff5f0';
        });
        
        document.querySelector('.upload-area').addEventListener('touchend', function() {
            this.style.backgroundColor = '#f8f9fa';
        });
    </script>
