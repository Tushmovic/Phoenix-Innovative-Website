<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
    <style>
        /* Hero Section */
        .page-hero {
            background: linear-gradient(135deg, #FF6B35, #F25F3A, #E71D36);
            color: white;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }

        .page-hero h1 {
            color: white !important;
            font-size: 3.5rem;
            font-weight: 800;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .page-hero p {
            color: rgba(255,255,255,0.95) !important;
            font-size: 1.4rem;
        }

        .page-hero .btn-light {
            background: white;
            color: #333 !important;
            border: none;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 8px;
            -webkit-tap-highlight-color: transparent;
        }

        .page-hero .btn-light:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(255,255,255,0.3);
        }

        .page-hero .btn-light:active {
            transform: scale(0.95);
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Benefit Cards */
        .benefit-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            height: 100%;
            transition: all 0.3s ease;
            text-align: center;
        }

        .benefit-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(255,107,53,0.15);
        }

        .benefit-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: white;
            font-size: 28px;
            transition: all 0.3s ease;
        }

        .benefit-card:hover .benefit-icon {
            transform: scale(1.1) rotate(5deg);
        }

        .benefit-card h4 {
            color: #333 !important;
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .benefit-card p {
            color: #666 !important;
        }

        /* Stats Cards */
        .stats-card {
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            color: white;
            padding: 40px 20px;
            border-radius: 15px;
            text-align: center;
            transition: all 0.3s ease;
        }

        .stats-card:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 20px 40px rgba(255,107,53,0.3);
        }

        .stats-number {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 10px;
            color: white !important;
        }

        .stats-card p {
            color: rgba(255,255,255,0.95) !important;
        }

        /* Culture Cards */
        .culture-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            height: 100%;
            border-left: 4px solid #FF6B35;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .culture-card:hover {
            transform: translateX(10px);
            box-shadow: 0 20px 40px rgba(255,107,53,0.15);
        }

        .culture-card h4 {
            color: #333 !important;
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .culture-card p {
            color: #666 !important;
        }

        .value-badge {
            display: inline-block;
            padding: 5px 15px;
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            color: white !important;
            border-radius: 25px;
            font-size: 12px;
            margin: 2px;
        }

        /* Job Cards */
        .job-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 30px;
            margin: 50px 0;
        }

        .job-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            border: 2px solid transparent;
        }

        .job-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #FF6B35, #4361EE);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }

        .job-card:hover {
            transform: translateY(-15px);
            border-color: #FF6B35;
            box-shadow: 0 30px 50px rgba(255,107,53,0.15);
        }

        .job-card:hover::before {
            transform: scaleX(1);
        }

        .job-card:active {
            transform: translateY(-5px);
        }

        .job-type {
            display: inline-block;
            padding: 5px 15px;
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            color: white !important;
            border-radius: 25px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .job-title {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 10px;
            color: #333 !important;
        }

        .job-location {
            color: #6c757d !important;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .job-location i {
            color: #FF6B35 !important;
        }

        .job-tags {
            margin: 20px 0;
        }

        .job-tag {
            display: inline-block;
            padding: 5px 12px;
            background: #f8f9fa;
            border-radius: 20px;
            font-size: 12px;
            margin: 2px;
            color: #666 !important;
        }

        .job-card p {
            color: #666 !important;
        }

        .btn-primary {
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            border: none;
            color: white !important;
            padding: 12px 25px;
            font-weight: 600;
            border-radius: 8px;
            width: 100%;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            -webkit-tap-highlight-color: transparent;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(255,107,53,0.4);
        }

        .btn-primary:active {
            transform: scale(0.95);
        }

        /* Testimonial Cards */
        .testimonial-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            margin: 20px 0;
            position: relative;
        }

        .employee-image {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #FF6B35;
        }

        .testimonial-card h5 {
            color: #333 !important;
            font-weight: 700;
        }

        .testimonial-card small {
            color: #666 !important;
        }

        .testimonial-card p {
            color: #333 !important;
            font-size: 1rem;
            line-height: 1.6;
        }

        /* Application Form */
        .application-form {
            background: white;
            padding: 50px;
            border-radius: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        .form-label {
            color: #333 !important;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .form-control, .form-select {
            padding: 12px 20px;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            transition: all 0.3s ease;
            color: #333 !important;
            font-size: 16px; /* Prevents zoom on iOS */
        }

        .form-control:focus, .form-select:focus {
            border-color: #FF6B35;
            box-shadow: 0 0 0 0.25rem rgba(255,107,53,0.25);
        }

        .form-control::placeholder {
            color: #999 !important;
        }

        .upload-area {
            border: 2px dashed #e9ecef;
            border-radius: 10px;
            padding: 30px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            background: #f8f9fa;
            -webkit-tap-highlight-color: transparent;
        }

        .upload-area:hover {
            border-color: #FF6B35;
            background: #fff5f0;
        }

        .upload-area:active {
            transform: scale(0.98);
        }

        .upload-area i {
            font-size: 3rem;
            color: #FF6B35 !important;
            margin-bottom: 15px;
        }

        .upload-area h5 {
            color: #333 !important;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .upload-area p {
            color: #666 !important;
        }

        .btn-submit {
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            border: none;
            color: white !important;
            padding: 15px 30px;
            font-weight: 600;
            border-radius: 8px;
            width: 100%;
            -webkit-tap-highlight-color: transparent;
        }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(255,107,53,0.4);
        }

        .btn-submit:active {
            transform: scale(0.95);
        }

        /* CTA Section */
        .cta-section {
            background: linear-gradient(135deg, #1C2541, #3A506B);
            color: white;
            padding: 80px 0;
        }

        .cta-section h2,
        .cta-section p,
        .cta-section .lead {
            color: white !important;
        }

        .cta-section .btn-light {
            background: white;
            color: #333 !important;
            border: none;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 8px;
            -webkit-tap-highlight-color: transparent;
        }

        .cta-section .btn-light:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(255,255,255,0.3);
        }

        .cta-section .btn-light:active {
            transform: scale(0.95);
        }

        /* Section Headers */
        h2.display-5 {
            color: #333 !important;
            font-size: 2.8rem;
            font-weight: 800;
            margin-bottom: 3rem;
        }

        .bg-light {
            background-color: #f8f9fa !important;
        }

        .text-muted {
            color: #666 !important;
        }

        /* Filter Select */
        .form-select {
            color: #333 !important;
            background-color: white;
            border: 2px solid #e9ecef;
            padding: 12px 30px 12px 20px;
            font-weight: 500;
            font-size: 16px;
        }

        .form-select option {
            color: #333 !important;
        }

        /* ===== MOBILE RESPONSIVE OPTIMIZATIONS ===== */
        
        /* Extra small devices (phones, 576px and down) */
        @media (max-width: 576px) {
            .page-hero {
                padding: 100px 0 60px;
            }
            
            .page-hero h1 {
                font-size: 2.2rem !important;
            }
            
            .page-hero p {
                font-size: 1rem !important;
                padding: 0 15px;
            }
            
            .page-hero .btn-light {
                padding: 12px 25px !important;
                font-size: 0.95rem !important;
                width: 100%;
                max-width: 280px;
            }
            
            .benefit-card {
                padding: 25px 20px;
            }
            
            .benefit-card h4 {
                font-size: 1.2rem !important;
            }
            
            .benefit-card p {
                font-size: 0.95rem !important;
            }
            
            .benefit-icon {
                width: 60px;
                height: 60px;
                font-size: 24px;
            }
            
            .stats-card {
                padding: 25px 15px;
            }
            
            .stats-number {
                font-size: 2rem !important;
            }
            
            .stats-card p {
                font-size: 0.9rem !important;
            }
            
            .culture-card {
                padding: 25px 20px;
            }
            
            .culture-card h4 {
                font-size: 1.2rem !important;
            }
            
            .culture-card p {
                font-size: 0.95rem !important;
            }
            
            .job-grid {
                grid-template-columns: 1fr;
                gap: 20px;
                margin: 30px 0;
            }
            
            .job-card {
                padding: 25px 20px;
            }
            
            .job-title {
                font-size: 1.5rem !important;
            }
            
            .job-location {
                font-size: 0.95rem !important;
            }
            
            .job-tag {
                font-size: 11px;
                padding: 4px 10px;
            }
            
            .job-card p {
                font-size: 0.95rem !important;
            }
            
            .btn-primary {
                padding: 10px 20px !important;
                font-size: 0.95rem !important;
            }
            
            .testimonial-card {
                padding: 25px 20px;
            }
            
            .testimonial-card h5 {
                font-size: 1.1rem !important;
            }
            
            .testimonial-card small {
                font-size: 0.85rem !important;
            }
            
            .testimonial-card p {
                font-size: 0.95rem !important;
            }
            
            .employee-image {
                width: 50px;
                height: 50px;
            }
            
            .application-form {
                padding: 30px 20px !important;
            }
            
            .application-form h2 {
                font-size: 1.8rem !important;
            }
            
            .form-control, .form-select {
                padding: 10px 15px !important;
                font-size: 16px !important;
            }
            
            .upload-area {
                padding: 20px 15px;
            }
            
            .upload-area i {
                font-size: 2.5rem;
            }
            
            .upload-area h5 {
                font-size: 1rem !important;
            }
            
            .upload-area p {
                font-size: 0.9rem !important;
            }
            
            .btn-submit {
                padding: 12px 20px !important;
                font-size: 1rem !important;
            }
            
            .cta-section {
                padding: 60px 0 !important;
            }
            
            .cta-section h2 {
                font-size: 1.8rem !important;
            }
            
            .cta-section p {
                font-size: 1rem !important;
            }
            
            .cta-section .btn-light {
                padding: 12px 25px !important;
                font-size: 0.95rem !important;
                width: 100%;
                max-width: 250px;
            }
        }
        
        /* Small devices (landscape phones, 577px to 767px) */
        @media (min-width: 577px) and (max-width: 767px) {
            .page-hero h1 {
                font-size: 2.8rem !important;
            }
            
            .benefit-card {
                padding: 25px 20px;
            }
            
            .stats-number {
                font-size: 2.5rem !important;
            }
            
            .job-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 20px;
            }
            
            .job-title {
                font-size: 1.3rem !important;
            }
            
            .cta-section h2 {
                font-size: 2rem !important;
            }
        }
        
        /* Medium devices (tablets, 768px to 991px) */
        @media (min-width: 768px) and (max-width: 991px) {
            .job-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .stats-number {
                font-size: 2.5rem !important;
            }
        }
        
        /* Touch target optimization for mobile */
        @media (max-width: 768px) {
            .btn-primary,
            .btn-submit,
            .page-hero .btn-light,
            .cta-section .btn-light,
            .upload-area,
            .form-control,
            .form-select {
                min-height: 44px;
            }
            
            /* Remove hover effects on mobile */
            .benefit-card:hover {
                transform: none;
            }
            
            .benefit-card:active {
                transform: translateY(-5px);
            }
            
            .culture-card:hover {
                transform: none;
            }
            
            .culture-card:active {
                transform: translateX(5px);
            }
            
            .job-card:hover {
                transform: none;
            }
            
            .job-card:active {
                transform: translateY(-5px);
            }
            
            .stats-card:hover {
                transform: none;
            }
            
            .stats-card:active {
                transform: scale(0.98);
            }
            
            .upload-area:hover {
                background: #f8f9fa;
                border-color: #e9ecef;
            }
            
            /* Improve spacing */
            .container {
                padding-left: 20px;
                padding-right: 20px;
            }
            
            /* Fix any horizontal scrolling */
            body {
                overflow-x: hidden;
                width: 100%;
            }
            
            /* Better grid for stats */
            .row.g-4 {
                --bs-gutter-y: 1rem;
            }
            
            /* Stats in 2 columns on mobile */
            .stats-section .col-md-3 {
                flex: 0 0 50%;
                max-width: 50%;
            }
            
            /* Filter select full width on mobile */
            #jobFilter {
                width: 100% !important;
                max-width: 300px;
            }
            
            /* Stack testimonials */
            .testimonial-card {
                margin-bottom: 20px;
            }
        }
        
        /* Fix for notched phones */
        @supports (padding: max(0px)) {
            .container {
                padding-left: max(20px, env(safe-area-inset-left));
                padding-right: max(20px, env(safe-area-inset-right));
            }
        }
        
        /* Reduced motion preferences */
        @media (prefers-reduced-motion: reduce) {
            .page-hero,
            .benefit-card,
            .benefit-icon,
            .stats-card,
            .culture-card,
            .job-card,
            .btn-primary,
            .btn-submit,
            .upload-area {
                animation: none;
                transition: none;
            }
            
            .page-hero::before {
                animation: none;
            }
        }
        
        /* Fix for file input on mobile */
        @media (max-width: 768px) {
            .upload-area {
                -webkit-tap-highlight-color: transparent;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/header'); %>
    <%- include('../partials/floating-buttons'); %>

    <!-- Hero Section -->
    <section class="page-hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8 mx-auto text-center" data-aos="fade-up">
                    <h1 class="display-3 fw-bold mb-4">Join Our Team</h1>
                    <p class="lead mb-4">Build your career at the forefront of technology innovation</p>
                    <a href="#openings" class="btn btn-light btn-lg px-5 py-3">View Open Positions</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Join Us -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">Why Join Phoenix?</h2>
            <div class="row g-4">
                <div class="col-12 col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="benefit-card">
                        <div class="benefit-icon">
                            <i class="bi bi-graph-up"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Career Growth</h4>
                        <p class="text-muted">Clear career progression paths, mentorship programs, and continuous learning opportunities.</p>
                    </div>
                </div>
                <div class="col-12 col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="benefit-card">
                        <div class="benefit-icon">
                            <i class="bi bi-heart"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Great Benefits</h4>
                        <p class="text-muted">Competitive salary, health insurance, pension, and performance bonuses.</p>
                    </div>
                </div>
                <div class="col-12 col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="benefit-card">
                        <div class="benefit-icon">
                            <i class="bi bi-people"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Great Culture</h4>
                        <p class="text-muted">Collaborative, inclusive environment where your ideas matter.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row g-4">
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="100">
                    <div class="stats-card">
                        <div class="stats-number counter-value" data-target="50">0</div>
                        <p class="mb-0">Team Members</p>
                    </div>
                </div>
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="200">
                    <div class="stats-card" style="background: linear-gradient(135deg, #4361EE, #3A0CA3);">
                        <div class="stats-number counter-value" data-target="40">0</div>
                        <p class="mb-0">Women in Tech</p>
                    </div>
                </div>
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="300">
                    <div class="stats-card" style="background: linear-gradient(135deg, #2EC4B6, #4361EE);">
                        <div class="stats-number counter-value" data-target="95">0</div>
                        <p class="mb-0">Employee Satisfaction</p>
                    </div>
                </div>
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="400">
                    <div class="stats-card" style="background: linear-gradient(135deg, #FF9F1C, #FF6B35);">
                        <div class="stats-number counter-value" data-target="5">0</div>
                        <p class="mb-0">Years Avg Tenure</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Culture Section -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">Our Culture</h2>
            <div class="row g-4">
                <div class="col-12 col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="culture-card">
                        <h4 class="fw-bold mb-3">Innovation First</h4>
                        <p>We encourage creative thinking and provide resources to explore new ideas and technologies.</p>
                        <span class="value-badge">Innovation</span>
                        <span class="value-badge">Creativity</span>
                    </div>
                </div>
                <div class="col-12 col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="culture-card">
                        <h4 class="fw-bold mb-3">Work-Life Balance</h4>
                        <p>Flexible hours, remote work options, and respect for personal time.</p>
                        <span class="value-badge">Flexibility</span>
                        <span class="value-badge">Wellness</span>
                    </div>
                </div>
                <div class="col-12 col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="culture-card">
                        <h4 class="fw-bold mb-3">Continuous Learning</h4>
                        <p>Training budgets, certification support, and regular knowledge-sharing sessions.</p>
                        <span class="value-badge">Growth</span>
                        <span class="value-badge">Learning</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Open Positions -->
    <section class="py-5 bg-light" id="openings">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">Open Positions</h2>
            
            <!-- Filter -->
            <div class="text-center mb-5" data-aos="fade-up">
