<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
    <style>
        /* Hero Section */
        .page-hero {
            background: linear-gradient(135deg, #FF9F1C, #FF6B35, #E71D36);
            color: white;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }

        .page-hero h1 {
            color: white !important;
            font-size: 3.5rem;
            font-weight: 800;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .page-hero p {
            color: rgba(255,255,255,0.95) !important;
            font-size: 1.4rem;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Value Cards */
        .values-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin: 50px 0;
        }

        .value-card {
            background: white;
            padding: 40px 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            height: 100%;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .value-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 0;
            background: linear-gradient(180deg, #FF6B35, #FF9F1C);
            transition: height 0.5s ease;
        }

        .value-card:hover {
            transform: translateY(-15px) scale(1.02);
            box-shadow: 0 30px 50px rgba(255,107,53,0.2);
        }

        .value-card:hover::before {
            height: 100%;
        }

        .value-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #FF6B35, #FF9F1C);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 25px;
            color: white;
            font-size: 32px;
            transition: all 0.3s ease;
        }

        .value-card:hover .value-icon {
            transform: rotateY(180deg);
        }

        .value-number {
            position: absolute;
            top: 20px;
            right: 20px;
            font-size: 5rem;
            font-weight: 800;
            color: rgba(255,107,53,0.1);
            line-height: 1;
        }

        .value-card h3 {
            color: #333 !important;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .value-card p {
            color: #666 !important;
            line-height: 1.6;
        }

        /* Principle Cards */
        .principle-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            height: 100%;
            border-left: 4px solid #FF6B35;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .principle-card:hover {
            transform: translateX(10px);
            box-shadow: 0 10px 30px rgba(255,107,53,0.1);
        }

        .principle-card h4 {
            color: #333 !important;
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .principle-card p {
            color: #666 !important;
        }

        /* Culture Cards */
        .culture-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            height: 100%;
            transition: all 0.3s ease;
        }

        .culture-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 30px 50px rgba(255,107,53,0.2);
        }

        .culture-image {
            height: 200px;
            background: linear-gradient(135deg, #FF6B35, #FF9F1C);
            position: relative;
            overflow: hidden;
        }

        .culture-image::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2), transparent);
            animation: rotate 20s linear infinite;
        }

        .culture-content {
            padding: 25px;
        }

        .culture-content h4 {
            color: #333 !important;
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .culture-content p {
            color: #666 !important;
        }

        /* Quote Card */
        .quote-card {
            background: linear-gradient(135deg, #1C2541, #3A506B);
            color: white;
            padding: 60px 40px;
            border-radius: 30px;
            position: relative;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        .quote-card h3 {
            color: white !important;
            font-size: 1.5rem;
            line-height: 1.6;
        }

        .quote-card h5 {
            color: white !important;
            font-weight: 700;
        }

        .quote-card p {
            color: rgba(255,255,255,0.8) !important;
        }

        /* Value Badges */
        .value-badge {
            display: inline-block;
            padding: 8px 20px;
            background: white;
            border-radius: 50px;
            margin: 5px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            border: 1px solid #e9ecef;
            color: #333 !important;
            font-weight: 500;
        }

        .value-badge:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(255,107,53,0.15);
            border-color: #FF6B35;
            color: #FF6B35 !important;
        }

        /* Testimonial Cards */
        .testimonial-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            margin: 20px 0;
            border-bottom: 4px solid #FF6B35;
        }

        .testimonial-card p {
            color: #333 !important;
            font-size: 1rem;
            line-height: 1.6;
            margin-bottom: 15px;
        }

        .testimonial-card h6 {
            color: #333 !important;
            font-weight: 700;
        }

        .testimonial-card small {
            color: #666 !important;
        }

        /* Stats Cards */
        .stats-card {
            background: linear-gradient(135deg, #FF6B35, #FF9F1C);
            color: white;
            padding: 40px 20px;
            border-radius: 15px;
            text-align: center;
            transition: all 0.3s ease;
        }

        .stats-card:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 20px 40px rgba(255,107,53,0.3);
        }

        .stats-card .display-4,
        .stats-card p {
            color: white !important;
        }

        /* CTA Section */
        .cta-section {
            background: linear-gradient(135deg, #FF6B35, #4361EE);
            color: white;
            padding: 80px 0;
        }

        .cta-section h2,
        .cta-section p,
        .cta-section .lead {
            color: white !important;
        }

        .cta-section .btn-light {
            background: white;
            color: #333 !important;
            border: none;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 8px;
        }

        .cta-section .btn-outline-light {
            background: transparent;
            border: 2px solid white;
            color: white !important;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 8px;
        }

        .cta-section .btn-outline-light:hover {
            background: white;
            color: #333 !important;
        }

        /* Section Headers */
        h2.display-5 {
            color: #333 !important;
            font-size: 2.8rem;
            font-weight: 800;
            margin-bottom: 3rem;
        }

        h3.text-center {
            color: #333 !important;
            font-size: 2rem;
            font-weight: 700;
        }

        .bg-light {
            background-color: #f8f9fa !important;
        }

        .text-muted {
            color: #666 !important;
        }

        .text-white-50 {
            color: rgba(255,255,255,0.8) !important;
        }

        @media (max-width: 768px) {
            .page-hero h1 {
                font-size: 2.5rem;
            }

            h2.display-5 {
                font-size: 2.2rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/header'); %>
    <%- include('../partials/floating-buttons'); %>

    <!-- Hero Section -->
    <section class="page-hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8 mx-auto text-center" data-aos="fade-up">
                    <h1 class="display-3 fw-bold mb-4">Our Core Values</h1>
                    <p class="lead mb-4">The principles that guide everything we do</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Values Section -->
    <section class="py-5">
        <div class="container">
            <div class="values-grid">
                <!-- Value 1 -->
                <div class="value-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="value-number">01</div>
                    <div class="value-icon">
                        <i class="bi bi-star"></i>
                    </div>
                    <h3 class="fw-bold mb-3">Excellence</h3>
                    <p class="text-muted">We strive for excellence in every project, every interaction, and every solution we deliver. Good enough is never enough – we aim to exceed expectations.</p>
                </div>

                <!-- Value 2 -->
                <div class="value-card" data-aos="fade-up" data-aos-delay="200">
                    <div class="value-number">02</div>
                    <div class="value-icon">
                        <i class="bi bi-lightbulb"></i>
                    </div>
                    <h3 class="fw-bold mb-3">Innovation</h3>
                    <p class="text-muted">We embrace change and continuously seek better ways to solve problems. Innovation is at the heart of everything we create.</p>
                </div>

                <!-- Value 3 -->
                <div class="value-card" data-aos="fade-up" data-aos-delay="300">
                    <div class="value-number">03</div>
                    <div class="value-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h3 class="fw-bold mb-3">Integrity</h3>
                    <p class="text-muted">We operate with honesty, transparency, and strong moral principles. Trust is the foundation of our relationships with clients, partners, and each other.</p>
                </div>

                <!-- Value 4 -->
                <div class="value-card" data-aos="fade-up" data-aos-delay="400">
                    <div class="value-number">04</div>
                    <div class="value-icon">
                        <i class="bi bi-people"></i>
                    </div>
                    <h3 class="fw-bold mb-3">Collaboration</h3>
                    <p class="text-muted">We believe in the power of teamwork. By working together – with clients, partners, and colleagues – we achieve extraordinary results.</p>
                </div>

                <!-- Value 5 -->
                <div class="value-card" data-aos="fade-up" data-aos-delay="500">
                    <div class="value-number">05</div>
                    <div class="value-icon">
                        <i class="bi bi-heart"></i>
                    </div>
                    <h3 class="fw-bold mb-3">Customer First</h3>
                    <p class="text-muted">Our clients' success is our success. We listen, understand, and deliver solutions that truly make a difference for their businesses.</p>
                </div>

                <!-- Value 6 -->
                <div class="value-card" data-aos="fade-up" data-aos-delay="600">
                    <div class="value-number">06</div>
                    <div class="value-icon">
                        <i class="bi bi-tree"></i>
                    </div>
                    <h3 class="fw-bold mb-3">Sustainability</h3>
                    <p class="text-muted">We're committed to building a better future through sustainable practices and solutions that benefit both business and environment.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Guiding Principles -->
    <section class="py-5 bg-light">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">Our Guiding Principles</h2>
            <div class="row g-4">
                <div class="col-md-6" data-aos="fade-right" data-aos-delay="100">
                    <div class="principle-card">
                        <h4 class="fw-bold mb-3">Quality First</h4>
                        <p class="text-muted mb-0">We never compromise on quality. Every solution undergoes rigorous testing and quality assurance before delivery.</p>
                    </div>
                </div>
                <div class="col-md-6" data-aos="fade-left" data-aos-delay="200">
                    <div class="principle-card">
                        <h4 class="fw-bold mb-3">Continuous Learning</h4>
                        <p class="text-muted mb-0">We invest in our team's growth, staying at the forefront of technology trends and best practices.</p>
                    </div>
                </div>
                <div class="col-md-6" data-aos="fade-right" data-aos-delay="300">
                    <div class="principle-card">
                        <h4 class="fw-bold mb-3">Transparent Communication</h4>
                        <p class="text-muted mb-0">Open, honest, and clear communication with all stakeholders – no surprises, no hidden agendas.</p>
                    </div>
                </div>
                <div class="col-md-6" data-aos="fade-left" data-aos-delay="400">
                    <div class="principle-card">
                        <h4 class="fw-bold mb-3">Social Responsibility</h4>
                        <p class="text-muted mb-0">We give back to our communities through technology education, mentorship, and sustainable initiatives.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Company Culture -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">Our Culture</h2>
            <div class="row g-4">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="culture-card">
                        <div class="culture-image"></div>
                        <div class="culture-content">
                            <h4 class="fw-bold mb-3">Diversity & Inclusion</h4>
                            <p class="text-muted">We celebrate diverse perspectives and create an inclusive environment where everyone can thrive.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="culture-card">
                        <div class="culture-image"></div>
                        <div class="culture-content">
                            <h4 class="fw-bold mb-3">Work-Life Balance</h4>
                            <p class="text-muted">We support flexible work arrangements and prioritize employee wellbeing and work-life harmony.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="culture-card">
                        <div class="culture-image"></div>
                        <div class="culture-content">
                            <h4 class="fw-bold mb-3">Professional Growth</h4>
                            <p class="text-muted">Continuous learning opportunities, mentorship programs, and clear career progression paths.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Value Badges -->
    <section class="py-5 bg-light">
        <div class="container">
            <h3 class="text-center mb-4" data-aos="fade-up">What We Stand For</h3>
            <div class="text-center" data-aos="fade-up" data-aos-delay="100">
                <span class="value-badge">Integrity</span>
                <span class="value-badge">Excellence</span>
                <span class="value-badge">Innovation</span>
                <span class="value-badge">Teamwork</span>
                <span class="value-badge">Respect</span>
                <span class="value-badge">Accountability</span>
                <span class="value-badge">Transparency</span>
                <span class="value-badge">Sustainability</span>
                <span class="value-badge">Diversity</span>
                <span class="value-badge">Customer Focus</span>
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">What Our Team Says</h2>
            <div class="row">
                <div class="col-md-6" data-aos="fade-right">
                    <div class="testimonial-card">
                        <p class="mb-3">"The values at Phoenix aren't just words on a wall – they're lived every day. It's why I've been proud to be part of this team for 5 years."</p>
                        <div>
                            <h6 class="mb-0">Chidi Okonkwo</h6>
                            <small class="text-muted">Senior Engineer</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6" data-aos="fade-left">
                    <div class="testimonial-card">
                        <p class="mb-3">"The collaborative culture here is amazing. Everyone supports each other, and we're all working toward the same goals."</p>
                        <div>
                            <h6 class="mb-0">Amara Nwachukwu</h6>
                            <small class="text-muted">Project Manager</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Quote Section -->
    <section class="py-5">
        <div class="container">
            <div class="quote-card" data-aos="zoom-in">
                <i class="bi bi-quote display-1 text-white opacity-25"></i>
                <h3 class="fw-light mb-4">"Our values are not just principles – they're promises. Promises to our clients, our team, and our community."</h3>
                <div>
                    <h5 class="fw-bold mb-0">Dr. Adewale Ogunleye</h5>
                    <p class="text-white-50 mb-0">Founder & CEO</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="100">
                    <div class="stats-card">
                        <div class="display-4 fw-bold counter-value" data-target="9">0</div>
                        <p class="mb-0">Years Strong</p>
                    </div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="200">
                    <div class="stats-card" style="background: linear-gradient(135deg, #4361EE, #3A0CA3);">
                        <div class="display-4 fw-bold counter-value" data-target="100">0</div>
                        <p class="mb-0">Team Members</p>
                    </div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="300">
                    <div class="stats-card" style="background: linear-gradient(135deg, #2EC4B6, #4361EE);">
                        <div class="display-4 fw-bold counter-value" data-target="95">0</div>
                        <p class="mb-0">Employee Satisfaction</p>
                    </div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="400">
                    <div class="stats-card" style="background: linear-gradient(135deg, #FF9F1C, #FF6B35);">
                        <div class="display-4 fw-bold counter-value" data-target="500">0</div>
                        <p class="mb-0">Projects Delivered</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8">
                    <h2 class="display-4 fw-bold mb-4" data-aos="fade-up">Share Our Values?</h2>
                    <p class="lead mb-5" data-aos="fade-up" data-aos-delay="100">Join a team where your values matter</p>
                    <div class="d-flex justify-content-center gap-3" data-aos="fade-up" data-aos-delay="200">
                        <a href="/about/careers" class="btn btn-light btn-lg px-5 py-3">View Careers</a>
                        <a href="/contact" class="btn btn-outline-light btn-lg px-5 py-3">Contact Us</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('../partials/footer'); %>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="/js/animations.js"></script>
    <script src="/js/transitions.js"></script>
    <script>
        AOS.init({
            duration: 1000,
            once: true,
            offset: 100
        });

        function animateCounter(element, target) {
            let current = 0;
            const increment = target / 50;
            const timer = setInterval(() => {
                current += increment;
                if (current >= target) {
                    element.textContent = target;
                    clearInterval(timer);
                } else {
                    element.textContent = Math.floor(current);
                }
            }, 20);
        }

        const counters = document.querySelectorAll('.counter-value');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const target = parseFloat(entry.target.dataset.target);
                    animateCounter(entry.target, target);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        counters.forEach(counter => observer.observe(counter));
    </script>
</body>
</html>