<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
    <style>
        /* Hero Section */
        .page-hero {
            background: linear-gradient(135deg, #4361EE, #3A0CA3, #2EC4B6);
            color: white;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }

        .page-hero h1 {
            color: white !important;
            font-size: 3.5rem;
            font-weight: 800;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .page-hero p {
            color: rgba(255,255,255,0.95) !important;
            font-size: 1.4rem;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Stats Cards */
        .stats-card {
            background: linear-gradient(135deg, #4361EE, #3A0CA3);
            color: white;
            padding: 40px 20px;
            border-radius: 15px;
            text-align: center;
            transition: all 0.3s ease;
        }

        .stats-card:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 20px 40px rgba(67,97,238,0.3);
        }

        .stats-card .display-4,
        .stats-card p {
            color: white !important;
        }

        /* Leadership Cards */
        .leadership-card {
            background: white;
            padding: 40px;
            border-radius: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            margin-bottom: 30px;
            transition: all 0.3s ease;
        }

        .leadership-card:hover {
            transform: translateX(20px);
            box-shadow: 0 30px 60px rgba(67,97,238,0.15);
        }

        .leader-image {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            overflow: hidden;
            border: 4px solid #4361EE;
            margin-right: 30px;
        }

        .leader-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .leadership-card h3 {
            color: #333 !important;
            font-size: 1.8rem;
            font-weight: 700;
        }

        .leadership-card h5 {
            color: #4361EE !important;
            font-weight: 600;
        }

        .leadership-card p {
            color: #666 !important;
            line-height: 1.6;
        }

        /* Team Grid */
        .team-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            margin: 50px 0;
        }

        .team-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            position: relative;
        }

        .team-card:hover {
            transform: translateY(-20px);
            box-shadow: 0 30px 50px rgba(67,97,238,0.2);
        }

        .team-image {
            height: 300px;
            position: relative;
            overflow: hidden;
        }

        .team-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: all 0.5s ease;
        }

        .team-card:hover .team-image img {
            transform: scale(1.1);
        }

        .team-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(to top, rgba(67,97,238,0.9), transparent);
            display: flex;
            align-items: flex-end;
            padding: 20px;
            opacity: 0;
            transition: all 0.3s ease;
        }

        .team-card:hover .team-overlay {
            opacity: 1;
        }

        .team-social {
            display: flex;
            gap: 15px;
        }

        .team-social a {
            width: 40px;
            height: 40px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #4361EE;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .team-social a:hover {
            transform: translateY(-5px) scale(1.1);
            background: #4361EE;
            color: white;
        }

        .team-info {
            padding: 20px;
            text-align: center;
        }

        .team-name {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 5px;
            color: #333 !important;
        }

        .team-position {
            color: #4361EE !important;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .team-badge {
            display: inline-block;
            padding: 5px 15px;
            background: linear-gradient(135deg, #4361EE, #3A0CA3);
            color: white !important;
            border-radius: 25px;
            font-size: 12px;
            font-weight: 600;
        }

        .value-badge {
            display: inline-block;
            padding: 5px 15px;
            background: #f0f0f0;
            border-radius: 20px;
            margin: 2px;
            font-size: 12px;
            color: #333 !important;
            font-weight: 500;
        }

        /* Department Tags */
        .department-tag {
            display: inline-block;
            padding: 8px 25px;
            background: linear-gradient(135deg, #4361EE, #3A0CA3);
            color: white !important;
            border-radius: 50px;
            margin: 5px;
            font-weight: 500;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .department-tag:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 10px 20px rgba(67,97,238,0.3);
        }

        /* Join Card */
        .join-card {
            background: linear-gradient(135deg, #4361EE, #2EC4B6);
            color: white;
            padding: 60px 40px;
            border-radius: 30px;
            text-align: center;
        }

        .join-card h2,
        .join-card p {
            color: white !important;
        }

        .join-card .btn-light {
            background: white;
            color: #333 !important;
            border: none;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 8px;
        }

        .join-card .btn-light:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(255,255,255,0.3);
        }

        /* CTA Section */
        .cta-section {
            background: linear-gradient(135deg, #1C2541, #3A506B);
            color: white;
            padding: 80px 0;
        }

        .cta-section h2,
        .cta-section p,
        .cta-section .lead {
            color: white !important;
        }

        .cta-section .btn-light {
            background: white;
            color: #333 !important;
            border: none;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 8px;
        }

        .cta-section .btn-outline-light {
            background: transparent;
            border: 2px solid white;
            color: white !important;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 8px;
        }

        .cta-section .btn-outline-light:hover {
            background: white;
            color: #333 !important;
        }

        /* Section Headers */
        h2.display-5 {
            color: #333 !important;
            font-size: 2.8rem;
            font-weight: 800;
            margin-bottom: 3rem;
        }

        .bg-light {
            background-color: #f8f9fa !important;
        }

        .text-primary {
            color: #4361EE !important;
        }

        @media (max-width: 768px) {
            .page-hero h1 {
                font-size: 2.5rem;
            }

            h2.display-5 {
                font-size: 2.2rem;
            }

            .leadership-card {
                padding: 25px;
            }

            .leader-image {
                margin-right: 0;
                margin-bottom: 20px;
            }

            .leadership-card .row {
                text-align: center;
            }

            .team-social {
                justify-content: center;
            }
        }
    </style>
</head>
