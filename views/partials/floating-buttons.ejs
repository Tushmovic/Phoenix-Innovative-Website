<!-- Floating Action Buttons - Always Visible -->
<link rel="stylesheet" href="/css/chatbot.css">

<div class="floating-buttons">
    <!-- WhatsApp Button -->
    <a href="https://wa.me/2349135926075?text=Hello%20Phoenix%20Innovative%20Technologies%2C%20I%20would%20like%20to%20know%20more%20about%20your%20services." 
       class="float-whatsapp" 
       target="_blank" 
       rel="noopener noreferrer"
       aria-label="Chat with us on WhatsApp">
        <i class="bi bi-whatsapp" aria-hidden="true"></i>
        <span class="button-tooltip">Chat on WhatsApp</span>
    </a>

    <!-- Chatbot Button -->
    <div class="chatbot-container">
        <div class="float-chatbot" id="chatbotToggle" role="button" tabindex="0" aria-label="Open AI chat assistant">
            <i class="bi bi-chat-dots" aria-hidden="true"></i>
            <span class="notification-badge" id="chatNotification" style="display: none;">1</span>
            <span class="button-tooltip">Ask AI Assistant</span>
        </div>
        
        <!-- Chatbot Window -->
        <div class="chatbot-window" id="chatbotWindow" role="dialog" aria-label="Chatbot window" aria-hidden="true">
            <div class="chatbot-header">
                <img src="/images/Phoenix_LOGO-removebg-preview.png" alt="Phoenix AI" loading="lazy">
                <div style="flex: 1;">
                    <h6 class="mb-0">Phoenix AI Assistant</h6>
                    <small>Online • 24/7 Support</small>
                </div>
                <button class="btn-close-white" id="closeChatbot" aria-label="Close chatbot"></button>
            </div>
            <div class="chatbot-messages" id="chatMessages" role="log" aria-live="polite">
                <div class="message">
                    <div class="bot-message">
                        👋 Hello! I'm your Phoenix AI assistant. How can I help you today?
                    </div>
                </div>
            </div>
            <div class="chatbot-input">
                <input type="text" id="chatInput" placeholder="Type your message..." aria-label="Type your message">
                <button id="sendMessage" aria-label="Send message"><i class="bi bi-send" aria-hidden="true"></i></button>
            </div>
        </div>
    </div>
</div>

<script src="/js/chatbot.js" defer></script>