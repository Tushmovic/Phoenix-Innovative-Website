                margin-bottom: 20px;
            }
            
            .stat-number {
                font-size: 2.8rem !important;
            }
        }
        
        /* Landscape mode for phones */
        @media (max-height: 500px) and (orientation: landscape) {
            .hero-carousel {
                height: 120vh;
            }
            
            .hero-content h1 {
                font-size: 2rem !important;
            }
            
