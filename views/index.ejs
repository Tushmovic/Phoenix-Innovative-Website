<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
    <style>
        /* Hero Carousel Fix - Add these styles at the top */
        .hero-carousel {
            position: relative;
            height: 100vh;
            overflow: hidden;
            margin-top: 0 !important;
        }
        
        .hero-carousel .carousel,
        .hero-carousel .carousel-inner,
        .hero-carousel .carousel-item {
            height: 100%;
        }
        
        .hero-carousel .carousel-item img {
            object-fit: cover;
            height: 100%;
            width: 100%;
        }
        
        .hero-content {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            background: linear-gradient(90deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 100%);
            z-index: 10;
        }
        
        /* Ensure carousel controls are visible */
        .carousel-control-prev,
        .carousel-control-next {
            z-index: 20;
        }
        
        .carousel-indicators {
            z-index: 20;
        }
        
        /* Rest of your existing styles */
        #testimonials {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            position: relative;
            overflow: hidden;
        }
        
        #testimonials::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(46,196,182,0.03) 0%, transparent 50%);
            animation: rotateSlow 40s linear infinite;
        }
        
        .testimonial-card-modern {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 30px;
            padding: 40px 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            z-index: 2;
            border: 1px solid rgba(255,255,255,0.5);
            height: 100%;
        }
        
        .testimonial-card-modern:hover {
            transform: translateY(-20px) scale(1.02);
            box-shadow: 0 40px 60px rgba(255,107,53,0.15);
            border-color: #FF6B35;
        }
        
        .testimonial-card-modern::before {
            content: '"';
            position: absolute;
            top: 10px;
            right: 30px;
            font-size: 120px;
            color: rgba(255,107,53,0.1);
            font-family: serif;
            line-height: 1;
        }
        
        .client-avatar-modern {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            overflow: hidden;
            border: 4px solid transparent;
            background: linear-gradient(135deg, #FF6B35, #4361EE);
            padding: 3px;
            margin-right: 20px;
            transition: all 0.3s ease;
        }
        
        .testimonial-card-modern:hover .client-avatar-modern {
            transform: rotate(360deg);
            border-color: #FF6B35;
        }
        
        .client-avatar-modern img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid white;
        }
        
        .testimonial-card-modern h5 {
            font-size: 1.3rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 5px;
        }
        
        .testimonial-card-modern small {
            color: #FF6B35;
            font-weight: 600;
        }
        
        .testimonial-card-modern p {
            color: #555;
            font-size: 1.1rem;
            line-height: 1.7;
            margin-top: 20px;
            position: relative;
            z-index: 2;
        }
        
        .testimonial-rating {
            margin-bottom: 15px;
        }
        
        .testimonial-rating i {
            color: #FFD700;
            font-size: 1.2rem;
            margin-right: 3px;
            animation: starPulse 2s infinite;
        }
        
        .testimonial-rating i:nth-child(2) { animation-delay: 0.2s; }
        .testimonial-rating i:nth-child(3) { animation-delay: 0.4s; }
        .testimonial-rating i:nth-child(4) { animation-delay: 0.6s; }
        .testimonial-rating i:nth-child(5) { animation-delay: 0.8s; }
        
        @keyframes starPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.2); opacity: 0.8; }
        }
        
        .client-logos-section {
            background: linear-gradient(135deg, #1C2541, #3A506B);
            position: relative;
            overflow: hidden;
            padding: 60px 0;
        }
        
        .client-logos-section h4 {
            color: white;
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 40px;
            text-align: center;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        .logo-marquee {
            position: relative;
            overflow: hidden;
            padding: 20px 0;
        }
        
        .logo-track {
            display: flex;
            animation: marquee 30s linear infinite;
            width: fit-content;
        }
        
        .logo-track:hover {
            animation-play-state: paused;
        }
        
        .logo-item {
            flex: 0 0 auto;
            width: 200px;
            margin: 0 40px;
            text-align: center;
            transition: all 0.3s ease;
        }
        
        .logo-item:hover {
            transform: translateY(-10px) scale(1.1);
        }
        
        .logo-icon {
            width: 100px;
            height: 100px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            font-size: 3rem;
            color: white;
            backdrop-filter: blur(5px);
            border: 2px solid rgba(255,255,255,0.2);
            transition: all 0.3s ease;
        }
        
        .logo-item:hover .logo-icon {
            background: linear-gradient(135deg, #FF6B35, #4361EE);
            border-color: white;
            transform: rotateY(180deg);
        }
        
        .logo-item p {
            color: rgba(255,255,255,0.8);
            font-weight: 600;
            font-size: 1rem;
        }
        
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        
        .stats-showcase {
            background: linear-gradient(135deg, #f8f9fa, white);
            padding: 80px 0;
            position: relative;
        }
        
        .stat-card-modern {
            background: white;
            padding: 40px 30px;
            border-radius: 30px;
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
            text-align: center;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
            z-index: 2;
        }
        
        .stat-card-modern::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #FF6B35, #4361EE);
            opacity: 0;
            transition: all 0.4s ease;
            z-index: -1;
        }
        
        .stat-card-modern:hover {
            transform: translateY(-20px) scale(1.05);
            color: white;
        }
        
        .stat-card-modern:hover::before {
            opacity: 1;
        }
        
        .stat-card-modern:hover .stat-number,
        .stat-card-modern:hover .stat-label {
            color: white;
        }
        
        .stat-number {
            font-size: 4rem;
            font-weight: 800;
            color: #FF6B35;
            line-height: 1;
            margin-bottom: 15px;
            transition: color 0.4s ease;
        }
        
        .stat-label {
            font-size: 1.3rem;
            font-weight: 600;
            color: #333;
            transition: color 0.4s ease;
        }
        
        .stat-icon {
            font-size: 3rem;
            color: rgba(255,107,53,0.2);
            margin-bottom: 20px;
            transition: all 0.4s ease;
        }
        
        .stat-card-modern:hover .stat-icon {
            color: rgba(255,255,255,0.3);
            transform: scale(1.2) rotate(360deg);
        }
        
        .case-studies {
            background: linear-gradient(135deg, #1C2541, #3A506B);
            padding: 80px 0;
            position: relative;
            overflow: hidden;
        }
        
        .case-studies h2 {
            color: white;
            font-size: 3rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 50px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        .case-study-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 30px 50px rgba(0,0,0,0.3);
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            height: 100%;
        }
        
        .case-study-card:hover {
            transform: translateY(-30px) scale(1.02);
            box-shadow: 0 50px 70px rgba(255,107,53,0.3);
        }
        
        .case-study-image {
            height: 250px;
            position: relative;
            overflow: hidden;
        }
        
        .case-study-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: all 0.8s ease;
        }
        
        .case-study-card:hover .case-study-image img {
            transform: scale(1.1) rotate(2deg);
        }
        
        .case-study-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(255,107,53,0.8), rgba(67,97,238,0.8));
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: all 0.4s ease;
        }
        
        .case-study-card:hover .case-study-overlay {
            opacity: 1;
        }
        
        .case-study-overlay span {
            color: white;
            font-size: 1.2rem;
            font-weight: 700;
            padding: 12px 25px;
            background: rgba(255,255,255,0.2);
            border-radius: 50px;
            backdrop-filter: blur(5px);
            transform: translateY(20px);
            transition: all 0.4s ease;
        }
        
        .case-study-card:hover .case-study-overlay span {
            transform: translateY(0);
        }
        
        .case-study-content {
            padding: 30px;
        }
        
        .case-study-content h5 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 10px;
        }
        
        .case-study-content p {
            color: #666;
            line-height: 1.6;
            margin-bottom: 20px;
        }
        
        .case-study-stats {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid #eee;
            padding-top: 20px;
        }
        
        .case-study-stats span {
            font-size: 1.2rem;
            font-weight: 700;
            color: #FF6B35;
        }
        
        .case-study-stats i {
            color: #4361EE;
            transition: all 0.3s ease;
        }
        
        .case-study-card:hover .case-study-stats i {
            transform: translateX(10px);
        }
        
        /* ===== TECHNOLOGY PARTNERS SECTION - SLIDING CAROUSEL ===== */
        .tech-partners {
            background: linear-gradient(135deg, #f8f9fa, #ffffff);
            padding: 100px 0;
            position: relative;
            overflow: hidden;
        }

        .tech-partners h2 {
            color: #333;
            font-size: 2.8rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 20px;
            position: relative;
            z-index: 2;
        }

        .tech-partners .lead {
            color: #666;
            text-align: center;
            max-width: 800px;
            margin: 0 auto 60px;
            position: relative;
            z-index: 2;
        }

        /* Logo Carousel Container */
        .logo-carousel-container {
            width: 100%;
            overflow: hidden;
            position: relative;
            z-index: 2;
            padding: 20px 0;
        }

        .logo-carousel-container::before,
        .logo-carousel-container::after {
            content: '';
            position: absolute;
            top: 0;
            width: 150px;
            height: 100%;
            z-index: 3;
            pointer-events: none;
        }

        .logo-carousel-container::before {
            left: 0;
            background: linear-gradient(90deg, rgba(255,255,255,0.9), transparent);
        }

        .logo-carousel-container::after {
            right: 0;
            background: linear-gradient(270deg, rgba(255,255,255,0.9), transparent);
        }

        .logo-carousel-track {
            display: flex;
            animation: scrollLogos 40s linear infinite;
            width: fit-content;
        }

        .logo-carousel-track:hover {
            animation-play-state: paused;
        }

        /* Logo Slide */
        .logo-slide {
            flex: 0 0 auto;
            width: 200px;
            margin: 0 20px;
        }

        /* Partner Logo Card */
        .partner-logo-card {
            background: white;
            border-radius: 15px;
            padding: 30px 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
            cursor: pointer;
            height: 180px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .partner-logo-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #FF6B35, #4361EE);
            transform: scaleX(0);
            transition: transform 0.4s ease;
        }

        .partner-logo-card:hover::before {
            transform: scaleX(1);
        }

        .partner-logo-card:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 20px 40px rgba(255,107,53,0.2);
        }

        .partner-logo {
            width: 100px;
            height: auto;
            max-height: 70px;
            object-fit: contain;
            margin-bottom: 15px;
            filter: grayscale(100%);
            opacity: 0.7;
            transition: all 0.4s ease;
        }

        .partner-logo-card:hover .partner-logo {
            filter: grayscale(0);
            opacity: 1;
            transform: scale(1.1);
        }

        .partner-name {
            color: #333;
            font-weight: 600;
            font-size: 1rem;
            text-align: center;
            transition: all 0.3s ease;
        }

        .partner-logo-card:hover .partner-name {
            color: #FF6B35;
        }

        /* Carousel Controls */
        .carousel-controls {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 40px;
            position: relative;
            z-index: 4;
        }

        .carousel-btn {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: white;
            border: 2px solid #FF6B35;
            color: #FF6B35;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .carousel-btn:hover {
            background: linear-gradient(135deg, #FF6B35, #4361EE);
            color: white;
            transform: scale(1.1) rotate(360deg);
            border-color: transparent;
            box-shadow: 0 10px 25px rgba(255,107,53,0.3);
        }

        /* Scroll Animation */
        @keyframes scrollLogos {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* Floating Particles */
        .floating-particle-1,
        .floating-particle-2,
        .floating-particle-3 {
            position: absolute;
            background: radial-gradient(circle, rgba(255,107,53,0.1), rgba(67,97,238,0.1));
            border-radius: 50%;
            pointer-events: none;
            z-index: 1;
        }

        .floating-particle-1 {
            width: 400px;
            height: 400px;
            top: -200px;
            right: -200px;
            animation: floatParticle1 25s linear infinite;
        }

        .floating-particle-2 {
            width: 300px;
            height: 300px;
            bottom: -150px;
            left: -150px;
            animation: floatParticle2 30s linear infinite reverse;
        }

        .floating-particle-3 {
            width: 200px;
            height: 200px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation: floatParticle3 35s linear infinite;
        }

        @keyframes floatParticle1 {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            33% { transform: translate(-80px, 80px) rotate(120deg); }
            66% { transform: translate(80px, -80px) rotate(240deg); }
        }

        @keyframes floatParticle2 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(100px, -100px) scale(1.3); }
        }

        @keyframes floatParticle3 {
            0% { transform: translate(-50%, -50%) rotate(0deg) scale(1); }
            50% { transform: translate(-50%, -50%) rotate(180deg) scale(1.5); }
            100% { transform: translate(-50%, -50%) rotate(360deg) scale(1); }
        }

        #cta-banner {
            background: linear-gradient(135deg, #FF6B35, #F25F3A, #E71D36) !important;
            position: relative;
            overflow: hidden;
            padding: 100px 0 !important;
        }
        
        #cta-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 60%);
            animation: rotateSlow 30s linear infinite;
        }
        
        #cta-banner::after {
            content: '';
            position: absolute;
            bottom: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
            animation: rotateSlow 40s linear infinite reverse;
        }
        
        @keyframes rotateSlow {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        #cta-banner h2 {
            color: #FF6B35;
            font-size: 3rem;
            font-weight: 800;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
            position: relative;
            z-index: 2;
        }
        
        #cta-banner p {
            color: #FF6B35;
            font-size: 1.3rem;
            position: relative;
            z-index: 2;
        }
        
        #cta-banner .btn-warning {
            background: white;
            color: #FF6B35;
            border: none;
            padding: 15px 40px;
            font-size: 1.2rem;
            font-weight: 700;
            border-radius: 50px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            z-index: 2;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }
        
        #cta-banner .btn-warning:hover {
            transform: scale(1.1) translateY(-5px);
            box-shadow: 0 20px 30px rgba(0,0,0,0.3);
            color: #F25F3A;
        }
        
        .floating-particle {
            position: absolute;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            pointer-events: none;
            z-index: 1;
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0) translateX(0); }
            25% { transform: translateY(-20px) translateX(10px); }
            50% { transform: translateY(-10px) translateX(-10px); }
            75% { transform: translateY(10px) translateX(-20px); }
        }
        
        /* ===== MOBILE RESPONSIVE OPTIMIZATIONS ===== */
        
        /* Extra small devices (phones, 576px and down) */
        @media (max-width: 576px) {
            /* Hero Section */
            .hero-carousel {
                height: 80vh;
            }
            
            .hero-content h1 {
                font-size: 2rem !important;
                line-height: 1.3;
            }
            
            .hero-content p {
                font-size: 1rem !important;
            }
            
            .hero-content .btn {
                padding: 10px 20px !important;
                font-size: 1rem !important;
                width: 100%;
            }
            
            .carousel-caption {
                display: none !important;
            }
            
            /* Service Cards */
            .service-image-card {
                margin-bottom: 20px;
            }
            
            .service-title {
                font-size: 1.3rem !important;
            }
            
            .service-text {
                font-size: 0.95rem !important;
            }
            
            .service-btn {
                padding: 8px 20px !important;
                font-size: 0.95rem !important;
            }
            
            /* Testimonials */
            .testimonial-card-modern {
                padding: 25px 20px !important;
            }
            
            .testimonial-card-modern h5 {
                font-size: 1.1rem !important;
            }
            
            .testimonial-card-modern p {
                font-size: 0.95rem !important;
            }
            
            .client-avatar-modern {
                width: 60px !important;
                height: 60px !important;
                margin-right: 15px !important;
            }
            
            /* Stats Section */
            .stats-showcase {
                padding: 40px 0 !important;
            }
            
            .stat-card-modern {
                padding: 25px 15px !important;
            }
            
            .stat-number {
                font-size: 2.2rem !important;
            }
            
            .stat-label {
                font-size: 1rem !important;
            }
            
            .stat-icon {
                font-size: 2.2rem !important;
            }
            
            /* Case Studies */
            .case-studies {
                padding: 40px 0 !important;
            }
            
            .case-studies h2 {
                font-size: 2rem !important;
                margin-bottom: 30px !important;
            }
            
            .case-study-content {
                padding: 20px !important;
            }
            
            .case-study-content h5 {
                font-size: 1.2rem !important;
            }
            
            .case-study-stats span {
                font-size: 1rem !important;
            }
            
            /* Technology Partners */
            .tech-partners {
                padding: 40px 0 !important;
            }
            
            .tech-partners h2 {
                font-size: 2rem !important;
            }
            
            .tech-partners .lead {
                font-size: 1rem !important;
                margin-bottom: 30px !important;
            }
            
            .logo-slide {
                width: 120px !important;
                margin: 0 8px !important;
            }
            
            .partner-logo-card {
                height: 120px !important;
                padding: 15px 10px !important;
            }
            
            .partner-logo {
                width: 60px !important;
                max-height: 40px !important;
            }
            
            .partner-name {
                font-size: 0.8rem !important;
            }
            
            .carousel-btn {
                width: 40px !important;
                height: 40px !important;
                font-size: 1.2rem !important;
            }
            
            .logo-carousel-container::before,
            .logo-carousel-container::after {
                width: 40px !important;
            }
            
            /* CTA Banner */
            #cta-banner {
                padding: 50px 0 !important;
            }
            
            #cta-banner h2 {
                font-size: 1.8rem !important;
            }
            
            #cta-banner p {
                font-size: 1rem !important;
            }
            
            #cta-banner .btn-warning {
                padding: 12px 25px !important;
                font-size: 1rem !important;
            }
        }
        
        /* Small devices (landscape phones, 576px to 767px) */
        @media (min-width: 577px) and (max-width: 767px) {
            .hero-content h1 {
                font-size: 2.5rem !important;
            }
            
