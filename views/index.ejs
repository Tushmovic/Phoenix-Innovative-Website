<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
</head>
<body>
    <%- include('partials/header'); %>

           <!-- Hero Carousel Section -->
    <section class="hero-carousel">
        <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="3"></button>
            </div>
            <div class="carousel-inner">
                <!-- Slide 1 -->
                <div class="carousel-item active">
                    <img src="/images/Solar Banner 1.png" class="d-block w-100" alt="Solar Energy Solutions">
                    <div class="carousel-caption d-none d-md-block">
                        <h3>Renewable Energy</h3>
                    </div>
                </div>
                <!-- Slide 2 -->
                <div class="carousel-item">
                    <img src="/images/Networking BANNER 1.png" class="d-block w-100" alt="Network Infrastructure">
                    <div class="carousel-caption d-none d-md-block">
                        <h3>Network Infrastructure & Connectivity</h3>
                    </div>
                </div>
                <!-- Slide 3 -->
                <div class="carousel-item">
                    <img src="/images/CCTV Banner 1.png" class="d-block w-100" alt="Security Systems">
                    <div class="carousel-caption d-none d-md-block">
                        <h3>CCTV & Security Systems</h3>
                    </div>
                </div>
                <!-- Slide 4 -->
                <div class="carousel-item">
                    <img src="/images/Consultant Banner 1.png" class="d-block w-100" alt="IT Solutions">
                    <div class="carousel-caption d-none d-md-block">
                        <h3>IT Consulting & Software Development</h3>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
        
        <!-- Hero Content Overlay -->
        <div class="hero-content">
            <div class="container">
                <div class="row align-items-center min-vh-100">
                    <div class="col-lg-6 text-white">
                        <h1 class="display-4 fw-bold mb-4">Building Intelligent Systems for a Smarter World</h1>
                        <p class="lead mb-4">From robust network infrastructure and seamless connectivity to advanced security systems and sustainable solar power – we provide the complete technology foundation your business needs to thrive.</p>
                        <a href="/contact" class="btn btn-warning btn-lg px-4 py-2 fw-bold">Call Us Today</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

       <!-- Services Preview Section -->
    <section class="py-5" id="services">
        <div class="container">
            <h2 class="text-center mb-5">Our Services</h2>
            <div class="row g-4">
                <!-- Service 1 - Renewable Energy -->
                <div class="col-md-6 col-lg-4">
                    <div class="service-image-card">
                        <div class="service-image-wrapper">
                            <img src="/images/solar_installers.jpg" class="service-image front-image" alt="Solar Installation">
                            <img src="/images/Solar Banner 1.png" class="service-image back-image" alt="Solar Panel Details">
                        </div>
                        <div class="service-content">
                            <h5 class="service-title">Renewable Energy</h5>
                            <p class="service-text">Harness the sun's power with our custom renewable energy solutions.</p>
                            <a href="/contact" class="btn service-btn">Get Quote</a>
                        </div>
                    </div>
                </div>
                
                <!-- Service 2 - CCTV & Security -->
                <div class="col-md-6 col-lg-4">
                    <div class="service-image-card">
                        <div class="service-image-wrapper">
                            <img src="/images/CCTV Banner 2.png" class="service-image front-image" alt="CCTV Installation">
                            <img src="/images/CCTV Banner 1.png" class="service-image back-image" alt="Security Monitoring">
                        </div>
                        <div class="service-content">
                            <h5 class="service-title">CCTV & Security Systems</h5>
                            <p class="service-text">Advanced surveillance systems to protect your people and assets.</p>
                            <a href="/contact" class="btn service-btn">Get Quote</a>
                        </div>
                    </div>
                </div>
                
                <!-- Service 3 - Network Infrastructure -->
                <div class="col-md-6 col-lg-4">
                    <div class="service-image-card">
                        <div class="service-image-wrapper">
                            <img src="/images/Networking BANNER 1.png" class="service-image front-image" alt="Network Setup">
                            <img src="/images/CAT6 Cable.png" class="service-image back-image" alt="Server Room">
                        </div>
                        <div class="service-content">
                            <h5 class="service-title">Network Infrastructure</h5>
                            <p class="service-text">Build a fast and reliable digital backbone for your business.</p>
                            <a href="/contact" class="btn service-btn">Get Quote</a>
                        </div>
                    </div>
                </div>
                
                <!-- Service 4 - ISP & Internet -->
                <div class="col-md-6 col-lg-4">
                    <div class="service-image-card">
                        <div class="service-image-wrapper">
                            <img src="/images/fiber-cables-1200x675.jpg" class="service-image front-image" alt="Internet Setup">
                            <img src="/images/fibre-optic-connector-cables.jpg" class="service-image back-image" alt="Fiber Installation">
                        </div>
                        <div class="service-content">
                            <h5 class="service-title">Internet Service Provider</h5>
                            <p class="service-text">Enterprise-grade internet connectivity and fiber solutions.</p>
                            <a href="/contact" class="btn service-btn">Get Quote</a>
                        </div>
                    </div>
                </div>
                
                <!-- Service 5 - Web Development -->
                <div class="col-md-6 col-lg-4">
                    <div class="service-image-card">
                        <div class="service-image-wrapper">
                            <img src="/images/website-development-process-full-guide-1-fb.jpg" class="service-image front-image" alt="Web Development">
                            <img src="/images/website-design-1024x683.jpg" class="service-image back-image" alt="Coding Process">
                        </div>
                        <div class="service-content">
                            <h5 class="service-title">Software Development</h5>
                            <p class="service-text">Fast, secure, and engaging software tailored to your business.</p>
                            <a href="/contact" class="btn service-btn">Get Quote</a>
                        </div>
                    </div>
                </div>
                
                <!-- Service 6 - IT Consulting -->
                <div class="col-md-6 col-lg-4">
                    <div class="service-image-card">
                        <div class="service-image-wrapper">
                            <img src="/images/Consultant Banner 1.png" class="service-image front-image" alt="IT Consulting">
                            <img src="/images/Procurement.jpg" class="service-image back-image" alt="Business Meeting">
                        </div>
                        <div class="service-content">
                            <h5 class="service-title">IT Consulting & Procurement</h5>
                            <p class="service-text">Strategic technology consulting and seamless procurement.</p>
                            <a href="/contact" class="btn service-btn">Get Quote</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
        <!-- Why Choose Us Section -->
    <section class="py-5 bg-light" id="why-choose-us">
        <div class="container">
            <h2 class="text-center mb-5">Why Choose Phoenix Innovative Technologies?</h2>
            <div class="row g-4">
                <div class="col-md-6 col-lg-3">
                    <div class="text-center p-4">
                        <div class="feature-icon mb-3">
                            <i class="bi bi-star-fill display-4 text-warning"></i>
                        </div>
                        <h4 class="fw-bold">Expert Team</h4>
                        <p>Our certified professionals bring years of industry experience and technical expertise to every project.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="text-center p-4">
                        <div class="feature-icon mb-3">
                            <i class="bi bi-shield-check display-4 text-primary"></i>
                        </div>
                        <h4 class="fw-bold">Quality Assurance</h4>
                        <p>We use only premium components and follow industry best practices for reliable, long-lasting solutions.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="text-center p-4">
                        <div class="feature-icon mb-3">
                            <i class="bi bi-clock-history display-4 text-success"></i>
                        </div>
                        <h4 class="fw-bold">24/7 Support</h4>
                        <p>Round-the-clock technical support and maintenance to ensure your systems are always operational.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="text-center p-4">
                        <div class="feature-icon mb-3">
                            <i class="bi bi-award display-4 text-danger"></i>
                        </div>
                        <h4 class="fw-bold">End-to-End Solutions</h4>
                        <p>From consultation to installation and maintenance - we handle every aspect of your technology needs.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
        <!-- Testimonials Section -->
    <section class="py-5" id="testimonials">
        <div class="container">
            <h2 class="text-center mb-5">What Our Clients Say</h2>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="testimonial-card p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="client-avatar me-3">
                                <i class="bi bi-person-circle display-6 text-secondary"></i>
                            </div>
                            <div>
                                <h5 class="mb-0">James Okafor</h5>
                                <small class="text-muted">CEO, GreenTech Solutions</small>
                            </div>
                        </div>
                        <p class="mb-0">"Phoenix transformed our office with a complete solar solution. Professional, efficient, and saved us 40% on energy costs!"</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="testimonial-card p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="client-avatar me-3">
                                <i class="bi bi-person-circle display-6 text-secondary"></i>
                            </div>
                            <div>
                                <h5 class="mb-0">Sarah Johnson</h5>
                                <small class="text-muted">Manager, SecureBank Ltd</small>
                            </div>
                        </div>
                        <p class="mb-0">"Their CCTV installation gave us peace of mind. The team was professional and the system has been flawless for 2 years."</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="testimonial-card p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="client-avatar me-3">
                                <i class="bi bi-person-circle display-6 text-secondary"></i>
                            </div>
                            <div>
                                <h5 class="mb-0">Michael Chen</h5>
                                <small class="text-muted">Director, TechStart Inc</small>
                            </div>
                        </div>
                        <p class="mb-0">"Our network infrastructure has never been better. Fast, reliable, and their support team is always available when needed."</p>
                    </div>
                </div>
            </div>
            
            <!-- Client Logos -->
            <div class="mt-5 pt-4 border-top">
                <h4 class="text-center mb-4">Trusted By Industry Leaders</h4>
                <div class="row align-items-center justify-content-center g-4">
                    <div class="col-6 col-md-3 text-center">
                        <div class="client-logo">
                            <i class="bi bi-building display-5 text-muted"></i>
                            <p class="mt-2 small">Corporate Solutions</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3 text-center">
                        <div class="client-logo">
                            <i class="bi bi-hospital display-5 text-muted"></i>
                            <p class="mt-2 small">Healthcare Systems</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3 text-center">
                        <div class="client-logo">
                            <i class="bi bi-bank display-5 text-muted"></i>
                            <p class="mt-2 small">Financial Institutions</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3 text-center">
                        <div class="client-logo">
                            <i class="bi bi-shop display-5 text-muted"></i>
                            <p class="mt-2 small">Retail Chains</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
        <!-- Call to Action Banner -->
    <section class="py-5 bg-primary text-white" id="cta-banner">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h2 class="display-6 fw-bold mb-3">Ready to Transform Your Business Technology?</h2>
                    <p class="lead mb-0">Get a free consultation and quote from our experts today. No obligations, just professional advice.</p>
                </div>
                <div class="col-lg-4 text-lg-end text-center mt-4 mt-lg-0">
                    <a href="/contact" class="btn btn-warning btn-lg px-4 py-2 fw-bold">
                        <i class="bi bi-telephone me-2"></i>Contact Us Now
                    </a>
                </div>
            </div>
        </div>
    </section>
    <%- include('partials/footer'); %>
</body>
</html>