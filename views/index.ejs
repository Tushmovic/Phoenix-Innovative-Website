<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
</head>
<body>
    <%- include('partials/header'); %>

           <!-- Hero Carousel Section -->
    <section class="hero-carousel">
        <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="3"></button>
            </div>
            <div class="carousel-inner">
                <!-- Slide 1 -->
                <div class="carousel-item active">
                    <img src="/images/Solar Banner 1.png" class="d-block w-100" alt="Solar Energy Solutions">
                </div>
                <!-- Slide 2 -->
                <div class="carousel-item">
                    <img src="/images/Networking BANNER 1.png" class="d-block w-100" alt="Network Infrastructure">
                </div>
                <!-- Slide 3 -->
                <div class="carousel-item">
                    <img src="/images/CCTV Banner 1.png" class="d-block w-100" alt="Security Systems">
                </div>
                <!-- Slide 4 -->
                <div class="carousel-item">
                    <img src="/images/Consultant Banner 1.png" class="d-block w-100" alt="IT Solutions">
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
        
        <!-- Hero Content Overlay -->
        <div class="hero-content">
            <div class="container">
                <div class="row align-items-center min-vh-100">
                    <div class="col-lg-6 text-white">
                        <h1 class="display-4 fw-bold mb-4">Building Intelligent Systems for a Smarter World</h1>
                        <p class="lead mb-4">From robust network infrastructure and seamless connectivity to advanced security systems and sustainable solar power – we provide the complete technology foundation your business needs to thrive.</p>
                        <a href="/contact" class="btn btn-warning btn-lg px-4 py-2 fw-bold">Call Us Today</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Preview Section -->
    <section class="py-5" id="services">
        <div class="container">
            <h2 class="text-center mb-5">Our Services</h2>
            <div class="row g-4">
                <!-- Service 1 -->
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 service-card shadow-sm border-0">
                        <div class="card-body text-center">
                            <i class="bi bi-sun-fill text-warning display-6 mb-3"></i>
                            <h5 class="card-title">Renewable Energy & Solar</h5>
                            <p class="card-text">Harness the sun's power with our custom solar energy solutions.</p>
                        </div>
                    </div>
                </div>
                <!-- Service 2 -->
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 service-card shadow-sm border-0">
                        <div class="card-body text-center">
                            <i class="bi bi-camera-video-fill text-primary display-6 mb-3"></i>
                            <h5 class="card-title">CCTV & Security Systems</h5>
                            <p class="card-text">Advanced surveillance systems to protect your people and assets.</p>
                        </div>
                    </div>
                </div>
                <!-- Service 3 -->
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 service-card shadow-sm border-0">
                        <div class="card-body text-center">
                            <i class="bi bi-hdd-stack-fill text-info display-6 mb-3"></i>
                            <h5 class="card-title">Network Infrastructure</h5>
                            <p class="card-text">Build a fast and reliable digital backbone for your business.</p>
                        </div>
                    </div>
                </div>
                <!-- Service 4 -->
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 service-card shadow-sm border-0">
                        <div class="card-body text-center">
                            <i class="bi bi-wifi text-success display-6 mb-3"></i>
                            <h5 class="card-title">ISP & Internet Services</h5>
                            <p class="card-text">Enterprise-grade internet connectivity and fiber solutions.</p>
                        </div>
                    </div>
                </div>
                <!-- Service 5 -->
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 service-card shadow-sm border-0">
                        <div class="card-body text-center">
                            <i class="bi bi-code-slash text-dark display-6 mb-3"></i>
                            <h5 class="card-title">Web Development</h5>
                            <p class="card-text">Fast, secure, and engaging websites tailored to your business.</p>
                        </div>
                    </div>
                </div>
                <!-- Service 6 -->
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 service-card shadow-sm border-0">
                        <div class="card-body text-center">
                            <i class="bi bi-briefcase-fill text-secondary display-6 mb-3"></i>
                            <h5 class="card-title">IT Consulting & Procurement</h5>
                            <p class="card-text">Strategic technology consulting and seamless procurement.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('partials/footer'); %>
</body>
</html>