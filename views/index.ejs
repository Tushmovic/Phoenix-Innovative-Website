    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- Bootstrap JS (make sure this is included) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AOS Animation Library -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <!-- Custom JS -->
    <script src="/js/animations.js"></script>
    <script src="/js/transitions.js"></script>
    <script>
        // Initialize AOS
        AOS.init({
            duration: 1000,
            once: true,
            offset: 100
        });
        
        // Initialize Bootstrap Carousel with auto-slide
        document.addEventListener('DOMContentLoaded', function() {
            var heroCarousel = document.getElementById('heroCarousel');
            if (heroCarousel) {
                var carousel = new bootstrap.Carousel(heroCarousel, {
                    interval: 5000,
                    wrap: true,
                    ride: 'carousel'
                });
            }
        });
        
        // Counter animation for stats
        function animateCounter(element, target) {
            let current = 0;
            const increment = target / 50;
            const timer = setInterval(() => {
                current += increment;
                if (current >= target) {
                    element.textContent = target + (target === 99.9 ? '' : '+');
                    clearInterval(timer);
                } else {
                    element.textContent = Math.floor(current);
                }
            }, 20);
        }

        const counters = document.querySelectorAll('.counter-value');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const target = parseFloat(entry.target.dataset.target);
                    animateCounter(entry.target, target);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        counters.forEach(counter => observer.observe(counter));
    </script>
    <script>
        // Carousel Control Functions
        function slideCarousel(direction) {
            const track = document.querySelector('.logo-carousel-track');
            const slides = document.querySelectorAll('.logo-slide');
            const slideWidth = slides[0].offsetWidth + 40; // width + margin
            
            if (direction === 'next') {
                track.style.transition = 'transform 0.5s ease';
                track.style.transform = `translateX(-${slideWidth}px)`;
                
                setTimeout(() => {
                    track.style.transition = 'none';
                    track.appendChild(track.firstElementChild.cloneNode(true));
                    track.removeChild(track.firstElementChild);
                    track.style.transform = 'translateX(0)';
                }, 500);
            } else {
                track.style.transition = 'transform 0.5s ease';
                track.style.transform = `translateX(${slideWidth}px)`;
                
                setTimeout(() => {
                    track.style.transition = 'none';
                    track.insertBefore(track.lastElementChild.cloneNode(true), track.firstElementChild);
                    track.removeChild(track.lastElementChild);
                    track.style.transform = 'translateX(0)';
                }, 500);
            }
        }

        // Pause animation on hover
        document.querySelector('.logo-carousel-track').addEventListener('mouseenter', function() {
            this.style.animationPlayState = 'paused';
        });

        document.querySelector('.logo-carousel-track').addEventListener('mouseleave', function() {
            this.style.animationPlayState = 'running';
        });
    </script>
