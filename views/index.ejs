<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
    <style>
        /* ===== REVAMPED SECTION STYLES ===== */
        
        /* Testimonials Section - Modern Gradient Cards */
        #testimonials {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            position: relative;
            overflow: hidden;
        }
        
        #testimonials::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(46,196,182,0.03) 0%, transparent 50%);
            animation: rotateSlow 40s linear infinite;
        }
        
        .testimonial-card-modern {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 30px;
            padding: 40px 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            z-index: 2;
            border: 1px solid rgba(255,255,255,0.5);
            height: 100%;
        }
        
        .testimonial-card-modern:hover {
            transform: translateY(-20px) scale(1.02);
            box-shadow: 0 40px 60px rgba(255,107,53,0.15);
            border-color: #FF6B35;
        }
        
        .testimonial-card-modern::before {
            content: '"';
            position: absolute;
            top: 10px;
            right: 30px;
            font-size: 120px;
            color: rgba(255,107,53,0.1);
            font-family: serif;
            line-height: 1;
        }
        
        .client-avatar-modern {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            overflow: hidden;
            border: 4px solid transparent;
            background: linear-gradient(135deg, #FF6B35, #4361EE);
            padding: 3px;
            margin-right: 20px;
            transition: all 0.3s ease;
        }
        
        .testimonial-card-modern:hover .client-avatar-modern {
            transform: rotate(360deg);
            border-color: #FF6B35;
        }
        
        .client-avatar-modern img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid white;
        }
        
        .testimonial-card-modern h5 {
            font-size: 1.3rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 5px;
        }
        
        .testimonial-card-modern small {
            color: #FF6B35;
            font-weight: 600;
        }
        
        .testimonial-card-modern p {
            color: #555;
            font-size: 1.1rem;
            line-height: 1.7;
            margin-top: 20px;
            position: relative;
            z-index: 2;
        }
        
        .testimonial-rating {
            margin-bottom: 15px;
        }
        
        .testimonial-rating i {
            color: #FFD700;
            font-size: 1.2rem;
            margin-right: 3px;
            animation: starPulse 2s infinite;
        }
        
        .testimonial-rating i:nth-child(2) { animation-delay: 0.2s; }
        .testimonial-rating i:nth-child(3) { animation-delay: 0.4s; }
        .testimonial-rating i:nth-child(4) { animation-delay: 0.6s; }
        .testimonial-rating i:nth-child(5) { animation-delay: 0.8s; }
        
        @keyframes starPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.2); opacity: 0.8; }
        }
        
        /* Client Logos - Animated Marquee */
        .client-logos-section {
            background: linear-gradient(135deg, #1C2541, #3A506B);
            position: relative;
            overflow: hidden;
            padding: 60px 0;
        }
        
        .client-logos-section h4 {
            color: white;
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 40px;
            text-align: center;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        .logo-marquee {
            position: relative;
            overflow: hidden;
            padding: 20px 0;
        }
        
        .logo-track {
            display: flex;
            animation: marquee 30s linear infinite;
            width: fit-content;
        }
        
        .logo-track:hover {
            animation-play-state: paused;
        }
        
        .logo-item {
            flex: 0 0 auto;
            width: 200px;
            margin: 0 40px;
            text-align: center;
            transition: all 0.3s ease;
        }
        
        .logo-item:hover {
            transform: translateY(-10px) scale(1.1);
        }
        
        .logo-icon {
            width: 100px;
            height: 100px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            font-size: 3rem;
            color: white;
            backdrop-filter: blur(5px);
            border: 2px solid rgba(255,255,255,0.2);
            transition: all 0.3s ease;
        }
        
        .logo-item:hover .logo-icon {
            background: linear-gradient(135deg, #FF6B35, #4361EE);
            border-color: white;
            transform: rotateY(180deg);
        }
        
        .logo-item p {
            color: rgba(255,255,255,0.8);
            font-weight: 600;
            font-size: 1rem;
        }
        
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        
        .stats-showcase {
            background: linear-gradient(135deg, #f8f9fa, white);
            padding: 80px 0;
            position: relative;
        }
        
        .stat-card-modern {
            background: white;
            padding: 40px 30px;
            border-radius: 30px;
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
            text-align: center;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
            z-index: 2;
        }
        
        .stat-card-modern::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #FF6B35, #4361EE);
            opacity: 0;
            transition: all 0.4s ease;
            z-index: -1;
        }
        
        .stat-card-modern:hover {
            transform: translateY(-20px) scale(1.05);
            color: white;
        }
        
        .stat-card-modern:hover::before {
            opacity: 1;
        }
        
        .stat-card-modern:hover .stat-number,
        .stat-card-modern:hover .stat-label {
            color: white;
        }
        
        .stat-number {
            font-size: 4rem;
            font-weight: 800;
            color: #FF6B35;
            line-height: 1;
            margin-bottom: 15px;
            transition: color 0.4s ease;
        }
        
        .stat-label {
            font-size: 1.3rem;
            font-weight: 600;
            color: #333;
            transition: color 0.4s ease;
        }
        
        .stat-icon {
            font-size: 3rem;
            color: rgba(255,107,53,0.2);
            margin-bottom: 20px;
            transition: all 0.4s ease;
        }
        
        .stat-card-modern:hover .stat-icon {
            color: rgba(255,255,255,0.3);
            transform: scale(1.2) rotate(360deg);
        }
        
        /* Case Studies Section - New */
        .case-studies {
            background: linear-gradient(135deg, #1C2541, #3A506B);
            padding: 80px 0;
            position: relative;
            overflow: hidden;
        }
        
        .case-studies h2 {
            color: white;
            font-size: 3rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 50px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        .case-study-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 30px 50px rgba(0,0,0,0.3);
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            height: 100%;
        }
        
        .case-study-card:hover {
            transform: translateY(-30px) scale(1.02);
            box-shadow: 0 50px 70px rgba(255,107,53,0.3);
        }
        
        .case-study-image {
            height: 250px;
            position: relative;
            overflow: hidden;
        }
        
        .case-study-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: all 0.8s ease;
        }
        
        .case-study-card:hover .case-study-image img {
            transform: scale(1.1) rotate(2deg);
        }
        
        .case-study-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(255,107,53,0.8), rgba(67,97,238,0.8));
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: all 0.4s ease;
        }
        
        .case-study-card:hover .case-study-overlay {
            opacity: 1;
        }
        
        .case-study-overlay span {
            color: white;
            font-size: 1.2rem;
            font-weight: 700;
            padding: 12px 25px;
            background: rgba(255,255,255,0.2);
            border-radius: 50px;
            backdrop-filter: blur(5px);
            transform: translateY(20px);
            transition: all 0.4s ease;
        }
        
        .case-study-card:hover .case-study-overlay span {
            transform: translateY(0);
        }
        
        .case-study-content {
            padding: 30px;
        }
        
        .case-study-content h5 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 10px;
        }
        
        .case-study-content p {
            color: #666;
            line-height: 1.6;
            margin-bottom: 20px;
        }
        
        .case-study-stats {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid #eee;
            padding-top: 20px;
        }
        
        .case-study-stats span {
            font-size: 1.2rem;
            font-weight: 700;
            color: #FF6B35;
        }
        
        .case-study-stats i {
            color: #4361EE;
            transition: all 0.3s ease;
        }
        
        .case-study-card:hover .case-study-stats i {
            transform: translateX(10px);
        }
        
        /* Technology Partners Section - New */
        .tech-partners {
            background: linear-gradient(135deg, #f8f9fa, #FF6B35);
            padding: 80px 0;
        }
        
        .tech-partners h2 {
            color: #4361EE;
            font-size: 2.8rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 20px;
        }
        
        .tech-partners .lead {
            color: #4361EE;
            text-align: center;
            max-width: 800px;
            margin: 0 auto 50px;
        }
        
        .partner-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 40px;
            align-items: center;
        }
        
        .partner-item {
            text-align: center;
            filter: grayscale(100%);
            opacity: 0.9;
            transition: all 0.4s ease;
            cursor: pointer;
        }
        
        .partner-item:hover {
            filter: grayscale(0);
            opacity: 1;
            transform: translateY(-10px) scale(1.1);
        }
        
        .partner-item i {
            font-size: 4rem;
            color: #4361EE;
            margin-bottom: 15px;
        }
        
        .partner-item span {
            display: block;
            font-weight: 600;
            color: #333;
        }
        
        /* Call to Action - Enhanced */
        #cta-banner {
            background: linear-gradient(135deg, #FF6B35, #F25F3A, #E71D36) !important;
            position: relative;
            overflow: hidden;
            padding: 100px 0 !important;
        }
        
        #cta-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 60%);
            animation: rotateSlow 30s linear infinite;
        }
        
        #cta-banner::after {
            content: '';
            position: absolute;
            bottom: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
            animation: rotateSlow 40s linear infinite reverse;
        }
        
        @keyframes rotateSlow {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        #cta-banner h2 {
            color: #FF6B35;
            font-size: 3rem;
            font-weight: 800;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
            position: relative;
            z-index: 2;
        }
        
        #cta-banner p {
            color: #FF6B35;
            font-size: 1.3rem;
            position: relative;
            z-index: 2;
        }
        
        #cta-banner .btn-warning {
            background: white;
            color: #FF6B35;
            border: none;
            padding: 15px 40px;
            font-size: 1.2rem;
            font-weight: 700;
            border-radius: 50px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            z-index: 2;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }
        
        #cta-banner .btn-warning:hover {
            transform: scale(1.1) translateY(-5px);
            box-shadow: 0 20px 30px rgba(0,0,0,0.3);
            color: #F25F3A;
        }
        
        /* Floating Particles Animation */
        .floating-particle {
            position: absolute;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            pointer-events: none;
            z-index: 1;
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0) translateX(0); }
            25% { transform: translateY(-20px) translateX(10px); }
            50% { transform: translateY(-10px) translateX(-10px); }
            75% { transform: translateY(10px) translateX(-20px); }
        }
        
        /* Responsive Adjustments */
        @media (max-width: 768px) {
            .stat-number {
                font-size: 2.5rem;
            }
            
            .stat-label {
                font-size: 1.1rem;
            }
            
            .case-study-card {
                margin-bottom: 30px;
            }
            
            .partner-grid {
                grid-template-columns: repeat(3, 1fr);
                gap: 20px;
            }
            
            #cta-banner h2 {
                font-size: 2rem;
            }
        }
    </style>
</head>
<body>
    <%- include('partials/header'); %>
    
    <!-- Floating Buttons - Included ONCE at the top of body -->
    <%- include('partials/floating-buttons'); %>

    <!-- Hero Carousel Section -->
    <section class="hero-carousel">
        <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="3"></button>
            </div>
            <div class="carousel-inner">
                <!-- Slide 1 -->
                <div class="carousel-item active">
                    <img src="/images/Solar Banner 1.png" class="d-block w-100" alt="Solar Energy Solutions">
                    <div class="carousel-caption d-none d-md-block">
                        <h3>Renewable Energy</h3>
                    </div>
                </div>
                <!-- Slide 2 -->
                <div class="carousel-item">
                    <img src="/images/Networking BANNER 1.png" class="d-block w-100" alt="Network Infrastructure">
                    <div class="carousel-caption d-none d-md-block">
                        <h3>Network Infrastructure & Connectivity</h3>
                    </div>
                </div>
                <!-- Slide 3 -->
                <div class="carousel-item">
                    <img src="/images/CCTV Banner 1.png" class="d-block w-100" alt="Security Systems">
                    <div class="carousel-caption d-none d-md-block">
                        <h3>CCTV & Security Systems</h3>
                    </div>
                </div>
                <!-- Slide 4 -->
                <div class="carousel-item">
                    <img src="/images/Consultant Banner 1.png" class="d-block w-100" alt="IT Solutions">
                    <div class="carousel-caption d-none d-md-block">
                        <h3>IT Consulting & Software Development</h3>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
        
        <!-- Hero Content Overlay -->
        <div class="hero-content">
            <div class="container">
                <div class="row align-items-center min-vh-100">
                    <div class="col-lg-6 text-white">
                        <h1 class="display-4 fw-bold mb-4">Building Intelligent Systems for a Smarter World</h1>
                        <p class="lead mb-4">From robust network infrastructure and seamless connectivity to advanced security systems and sustainable solar power – we provide the complete technology foundation your business needs to thrive.</p>
                        <a href="/contact" class="btn btn-warning btn-lg px-4 py-2 fw-bold">Call Us Today</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Preview Section -->
    <section class="py-5" id="services">
        <div class="container">
            <h2 class="text-center mb-5">Our Services</h2>
            <div class="row g-4">
                <!-- Service 1 - Renewable Energy -->
                <div class="col-md-6 col-lg-4">
                    <div class="service-image-card">
                        <div class="service-image-wrapper">
                            <img src="/images/solar_installers.jpg" class="service-image front-image" alt="Solar Installation">
                            <img src="/images/Solar Banner 1.png" class="service-image back-image" alt="Solar Panel Details">
                        </div>
                        <div class="service-content">
                            <h5 class="service-title">Renewable Energy</h5>
                            <p class="service-text">Harness the sun's power with our custom renewable energy solutions.</p>
                            <a href="/contact" class="btn service-btn">Get Quote</a>
                        </div>
                    </div>
                </div>
                
                <!-- Service 2 - CCTV & Security -->
                <div class="col-md-6 col-lg-4">
                    <div class="service-image-card">
                        <div class="service-image-wrapper">
                            <img src="/images/CCTV Banner 2.png" class="service-image front-image" alt="CCTV Installation">
                            <img src="/images/CCTV Banner 1.png" class="service-image back-image" alt="Security Monitoring">
                        </div>
                        <div class="service-content">
                            <h5 class="service-title">CCTV & Security Systems</h5>
                            <p class="service-text">Advanced surveillance systems to protect your people and assets.</p>
                            <a href="/contact" class="btn service-btn">Get Quote</a>
                        </div>
                    </div>
                </div>
                
                <!-- Service 3 - Network Infrastructure -->
                <div class="col-md-6 col-lg-4">
                    <div class="service-image-card">
                        <div class="service-image-wrapper">
                            <img src="/images/Networking BANNER 1.png" class="service-image front-image" alt="Network Setup">
                            <img src="/images/CAT6 Cable.png" class="service-image back-image" alt="Server Room">
                        </div>
                        <div class="service-content">
                            <h5 class="service-title">Network Infrastructure</h5>
                            <p class="service-text">Build a fast and reliable digital backbone for your business.</p>
                            <a href="/contact" class="btn service-btn">Get Quote</a>
                        </div>
                    </div>
                </div>
                
                <!-- Service 4 - ISP & Internet -->
                <div class="col-md-6 col-lg-4">
                    <div class="service-image-card">
                        <div class="service-image-wrapper">
                            <img src="/images/fiber-cables-1200x675.jpg" class="service-image front-image" alt="Internet Setup">
                            <img src="/images/fibre-optic-connector-cables.jpg" class="service-image back-image" alt="Fiber Installation">
                        </div>
                        <div class="service-content">
                            <h5 class="service-title">Internet Service Provider</h5>
                            <p class="service-text">Enterprise-grade internet connectivity and fiber solutions.</p>
                            <a href="/contact" class="btn service-btn">Get Quote</a>
                        </div>
                    </div>
                </div>
                
                <!-- Service 5 - Web Development -->
                <div class="col-md-6 col-lg-4">
                    <div class="service-image-card">
                        <div class="service-image-wrapper">
                            <img src="/images/website-development-process-full-guide-1-fb.jpg" class="service-image front-image" alt="Web Development">
                            <img src="/images/website-design-1024x683.jpg" class="service-image back-image" alt="Coding Process">
                        </div>
                        <div class="service-content">
                            <h5 class="service-title">Software Development</h5>
                            <p class="service-text">Fast, secure, and engaging software tailored to your business.</p>
                            <a href="/contact" class="btn service-btn">Get Quote</a>
                        </div>
                    </div>
                </div>
                
                <!-- Service 6 - IT Consulting -->
                <div class="col-md-6 col-lg-4">
                    <div class="service-image-card">
                        <div class="service-image-wrapper">
                            <img src="/images/Consultant Banner 1.png" class="service-image front-image" alt="IT Consulting">
                            <img src="/images/Procurement.jpg" class="service-image back-image" alt="Business Meeting">
                        </div>
                        <div class="service-content">
                            <h5 class="service-title">IT Consulting & Procurement</h5>
                            <p class="service-text">Strategic technology consulting and seamless procurement.</p>
                            <a href="/contact" class="btn service-btn">Get Quote</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
      
    <!-- REVAMPED TESTIMONIALS SECTION -->
    <section class="py-5" id="testimonials">
        <div class="container position-relative">
            <h2 class="text-center mb-5" data-aos="fade-up" style="color: #333; font-size: 3rem; font-weight: 800;">What Our Clients Say</h2>
            <div class="row g-4">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="testimonial-card-modern">
                        <div class="d-flex align-items-center mb-3">
                            <div class="client-avatar-modern">
                                <img src="/images/Client 1.png" alt="James Okafor">
                            </div>
                            <div>
                                <h5 class="mb-0">James Okafor</h5>
                                <small>CEO, GreenTech Solutions</small>
                            </div>
                        </div>
                        <div class="testimonial-rating">
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                        </div>
                        <p>"Phoenix transformed our office with a complete solar solution. Professional, efficient, and saved us 40% on energy costs! Their expertise in renewable energy is unmatched."</p>
                    </div>
                </div>
                
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="testimonial-card-modern">
                        <div class="d-flex align-items-center mb-3">
                            <div class="client-avatar-modern">
                                <img src="/images/Client 3.png" alt="Sarah Johnson">
                            </div>
