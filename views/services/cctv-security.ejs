<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
    <style>
        .page-hero {
            background: linear-gradient(135deg, #3A0CA3, #4361EE, #2EC4B6);
            color: white;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }
        
        .page-hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 60%);
            animation: rotate 30s linear infinite;
        }
        
        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        .camera-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin: 40px 0;
        }
        
        .camera-item {
            background: rgba(255,255,255,0.1);
            border-radius: 15px;
            padding: 20px;
            text-align: center;
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
        }
        
        .camera-item:hover {
            transform: translateY(-10px);
            background: rgba(255,255,255,0.2);
        }
        
        .camera-item:active {
            transform: translateY(-5px);
        }
        
        .camera-item h6 {
            color: white;
        }
        
        .camera-icon {
            font-size: 3rem;
            margin-bottom: 15px;
            color: #2EC4B6;
        }
        
        .feature-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            height: 100%;
            border-bottom: 4px solid transparent;
        }
        
        .feature-card:hover {
            transform: translateY(-10px);
            border-bottom-color: #3A0CA3;
            box-shadow: 0 20px 40px rgba(58,12,163,0.15);
        }
        
        .feature-card:active {
            transform: translateY(-5px);
        }
        
        .feature-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #3A0CA3, #4361EE);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            color: white;
            font-size: 28px;
        }
        
        .security-badge {
            display: inline-block;
            padding: 10px 25px;
            background: linear-gradient(135deg, #3A0CA3, #4361EE);
            color: white;
            border-radius: 50px;
            margin: 5px;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            -webkit-tap-highlight-color: transparent;
        }
        
        .security-badge:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 10px 20px rgba(58,12,163,0.3);
        }
        
        .security-badge:active {
            transform: scale(0.95);
        }
        
        .stats-card {
            background: linear-gradient(135deg, #3A0CA3, #4361EE);
            color: white;
            padding: 40px 20px;
            border-radius: 15px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        .stats-card::after {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2), transparent);
            animation: rotate 20s linear infinite;
        }
        
        .stats-card:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 20px 40px rgba(58,12,163,0.3);
        }
        
        .stats-card:active {
            transform: scale(0.98);
        }
        
        .stats-number {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 10px;
            color: white;
        }
        
        .stats-card p {
            color: rgba(255,255,255,0.95);
        }
        
        .package-card {
            background: white;
            padding: 40px 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            height: 100%;
            position: relative;
            overflow: hidden;
        }
        
        .package-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 30px 50px rgba(58,12,163,0.2);
        }
        
        .package-card:active {
            transform: translateY(-5px);
        }
        
        .package-card.premium {
            border: 2px solid #3A0CA3;
        }
        
        .package-badge {
            position: absolute;
            top: 20px;
            right: -35px;
            background: linear-gradient(135deg, #3A0CA3, #4361EE);
            color: white;
            padding: 5px 40px;
            transform: rotate(45deg);
            font-size: 12px;
            font-weight: bold;
        }
        
        .package-card h3 {
            color: #333;
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 15px;
        }
        
        .package-card .display-4 {
            color: #3A0CA3;
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 20px;
        }
        
        .package-card ul li {
            color: #333;
            padding: 8px 0;
            border-bottom: 1px solid #eee;
        }
        
        .package-card ul li i {
            color: #28a745;
            margin-right: 10px;
        }
        
        .btn-outline-primary {
            color: #3A0CA3;
            border: 2px solid #3A0CA3;
            background: transparent;
            padding: 12px 20px;
            font-weight: 600;
            border-radius: 8px;
            transition: all 0.3s ease;
            -webkit-tap-highlight-color: transparent;
        }
        
        .btn-outline-primary:hover {
            background: #3A0CA3;
            color: white;
        }
        
        .btn-outline-primary:active {
            transform: scale(0.95);
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #3A0CA3, #4361EE);
            border: none;
            color: white;
            padding: 12px 20px;
            font-weight: 600;
            border-radius: 8px;
            -webkit-tap-highlight-color: transparent;
        }
        
        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(58,12,163,0.4);
        }
        
        .btn-primary:active {
            transform: scale(0.95);
        }
        
        .btn-light {
            background: white;
            border: none;
            color: #333;
            padding: 15px 30px;
            font-weight: 600;
            border-radius: 8px;
            -webkit-tap-highlight-color: transparent;
        }
        
        .btn-outline-light {
            background: transparent;
            border: 2px solid white;
            color: white;
            padding: 15px 30px;
            font-weight: 600;
            border-radius: 8px;
            -webkit-tap-highlight-color: transparent;
        }
        
        .btn-outline-light:hover {
            background: white;
            color: #333;
        }
        
        .btn-outline-light:active {
            transform: scale(0.95);
        }
        
        .tech-showcase {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            justify-content: center;
            margin: 40px 0;
        }
        
        .tech-item {
            width: 120px;
            height: 120px;
            background: white;
            border-radius: 50%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
        }
        
        .tech-item:hover {
            transform: scale(1.1) rotate(360deg);
            box-shadow: 0 20px 30px rgba(58,12,163,0.2);
        }
        
        .tech-item:active {
            transform: scale(0.95);
        }
        
        .tech-item i {
            font-size: 2.5rem;
            color: #3A0CA3;
            margin-bottom: 5px;
        }
        
        .tech-item span {
            color: #333;
        }
        
        .testimonial-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            margin: 20px 0;
            position: relative;
            border-left: 4px solid #3A0CA3;
        }
        
        .testimonial-card p {
            color: #333;
            font-size: 1rem;
            line-height: 1.6;
            margin-bottom: 15px;
        }
        
        .testimonial-card h6 {
            color: #333;
            font-weight: 700;
        }
        
        .testimonial-card small {
            color: #666;
        }
        
        .testimonial-card::before {
            content: '"';
            position: absolute;
            top: -20px;
            left: 20px;
            font-size: 100px;
            color: rgba(58,12,163,0.1);
            font-family: serif;
        }
        
        .monitoring-dashboard {
            background: #1a1a2e;
            border-radius: 20px;
            padding: 30px;
            color: white;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }
        
        .monitoring-dashboard h5 {
            color: white;
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 20px;
        }
        
        .camera-feed {
            background: #0f0f1f;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 15px;
            transition: all 0.3s ease;
        }
        
        .camera-feed:hover {
            background: #1f1f3f;
            transform: translateX(10px);
        }
        
        .camera-feed:active {
            transform: translateX(5px);
        }
        
        .camera-feed strong {
            color: white;
            font-size: 1rem;
        }
        
        .camera-feed small {
            color: rgba(255,255,255,0.7);
            font-size: 0.85rem;
        }
        
        .feed-indicator {
            width: 12px;
            height: 12px;
            background: #2EC4B6;
            border-radius: 50%;
            animation: blink 2s infinite;
        }
        
        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        h2.display-5 {
            color: #333;
            font-size: 2.8rem;
            font-weight: 800;
            margin-bottom: 3rem;
        }
        
        h3.text-center {
            color: #333;
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 2rem;
        }
        
        .bg-light {
            background-color: #f8f9fa;
        }
        
        .bg-light h2.display-5 {
            color: #333;
        }
        
        .bg-light p.lead {
            color: #666;
        }
        
        .cta-section {
            background: linear-gradient(135deg, #3A0CA3, #2EC4B6);
            color: white;
            padding: 80px 0;
        }
        
        .cta-section h2 {
            color: white;
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 20px;
        }
        
        .cta-section p {
            color: rgba(255,255,255,0.95);
            font-size: 1.3rem;
            margin-bottom: 30px;
        }
        
        .text-success {
            color: #28a745 !important;
        }
        
        .text-warning {
            color: #ffc107 !important;
        }
        
        .text-muted {
            color: #666 !important;
        }
        
        /* ===== MOBILE RESPONSIVE OPTIMIZATIONS ===== */
        
        /* Extra small devices (phones, 576px and down) */
        @media (max-width: 576px) {
            .page-hero {
                padding: 100px 0 60px;
            }
            
            .page-hero h1 {
                font-size: 2.2rem !important;
            }
            
            .page-hero p {
                font-size: 1rem !important;
            }
            
            .page-hero .d-flex {
                flex-direction: column;
                gap: 10px !important;
            }
            
            .page-hero .btn {
                width: 100%;
                padding: 12px !important;
                font-size: 1rem !important;
            }
            
            .camera-grid {
                grid-template-columns: repeat(3, 1fr);
                gap: 10px;
                margin: 20px 0;
            }
            
            .camera-item {
                padding: 15px 10px;
            }
            
            .camera-icon {
                font-size: 2rem;
            }
            
            .camera-item h6 {
                font-size: 0.8rem;
            }
            
            .feature-card {
                padding: 25px 20px;
            }
            
            .feature-card h4 {
                font-size: 1.2rem !important;
            }
            
            .feature-card p {
                font-size: 0.95rem !important;
            }
            
            .feature-icon {
                width: 60px;
                height: 60px;
                font-size: 24px;
            }
            
            .security-badge {
                padding: 8px 15px;
                font-size: 0.9rem;
                margin: 3px;
            }
            
            .stats-card {
                padding: 25px 15px;
            }
            
            .stats-number {
                font-size: 2rem !important;
            }
            
            .stats-card p {
                font-size: 0.9rem !important;
            }
            
            .monitoring-dashboard {
                padding: 20px;
                margin-top: 30px;
            }
            
            .monitoring-dashboard h5 {
                font-size: 1.2rem;
            }
            
            .camera-feed {
                padding: 12px;
            }
            
            .camera-feed strong {
                font-size: 0.95rem;
            }
            
            .camera-feed small {
                font-size: 0.8rem;
            }
            
            .package-card {
                padding: 30px 20px;
            }
            
            .package-card h3 {
                font-size: 1.5rem !important;
            }
            
            .package-card .display-4 {
                font-size: 2rem !important;
            }
            
            .package-card ul li {
                font-size: 0.95rem;
            }
            
            .package-badge {
                font-size: 10px;
                padding: 3px 30px;
                right: -30px;
            }
            
            .btn-outline-primary,
            .btn-primary {
                padding: 10px !important;
                font-size: 0.95rem !important;
            }
            
            .testimonial-card {
                padding: 25px 20px;
            }
            
            .testimonial-card p {
                font-size: 0.95rem !important;
            }
            
            .cta-section {
                padding: 60px 0 !important;
            }
            
            .cta-section h2 {
                font-size: 2rem !important;
            }
            
            .cta-section p {
                font-size: 1rem !important;
            }
            
            .cta-section .d-flex {
                flex-direction: column;
                gap: 10px !important;
            }
            
            .cta-section .btn {
                width: 100%;
                padding: 12px !important;
                font-size: 1rem !important;
            }
        }
        
        /* Small devices (landscape phones, 577px to 767px) */
        @media (min-width: 577px) and (max-width: 767px) {
            .page-hero h1 {
                font-size: 2.5rem !important;
            }
            
            .feature-card h4 {
                font-size: 1.2rem !important;
            }
            
            .stats-number {
                font-size: 2.2rem !important;
            }
            
            .package-card h3 {
                font-size: 1.5rem !important;
            }
            
            .package-card .display-4 {
                font-size: 2.2rem !important;
            }
            
            .cta-section h2 {
                font-size: 2.2rem !important;
            }
        }
        
        /* Medium devices (tablets, 768px to 991px) */
        @media (min-width: 768px) and (max-width: 991px) {
            .feature-card h4 {
                font-size: 1.2rem !important;
            }
            
            .stats-number {
                font-size: 2.5rem !important;
            }
            
            .package-card h3 {
                font-size: 1.5rem !important;
            }
            
            .package-card .display-4 {
                font-size: 2.2rem !important;
            }
        }
        
        /* Touch target optimization for mobile */
        @media (max-width: 768px) {
            .btn,
            .btn-outline-primary,
            .btn-primary,
            .btn-light,
            .btn-outline-light,
            .security-badge,
            .tech-item {
                min-height: 44px;
                min-width: 44px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }
            
            /* Remove hover effects on mobile */
            .camera-item:hover {
                transform: none;
            }
            
            .camera-item:active {
                transform: translateY(-5px);
            }
            
            .feature-card:hover {
                transform: none;
            }
            
            .feature-card:active {
                transform: translateY(-5px);
            }
            
            .package-card:hover {
                transform: none;
            }
            
            .package-card:active {
                transform: translateY(-5px);
            }
            
            .stats-card:hover {
                transform: none;
            }
            
            .stats-card:active {
                transform: scale(0.98);
            }
            
            .tech-item:hover {
                transform: none;
            }
            
            .tech-item:active {
                transform: scale(0.95);
            }
            
            .camera-feed:hover {
                transform: none;
            }
            
            .camera-feed:active {
                transform: translateX(5px);
            }
            
            /* Improve spacing */
            .container {
                padding-left: 20px;
                padding-right: 20px;
            }
            
            /* Fix any horizontal scrolling */
            body {
                overflow-x: hidden;
                width: 100%;
            }
            
            /* Better grid for stats */
            .row.g-4 {
                --bs-gutter-y: 1rem;
            }
            
            /* Stats in 2 columns on mobile */
            .stats-section .col-md-3 {
                flex: 0 0 50%;
                max-width: 50%;
            }
            
            /* Packages in full width on mobile */
            .packages-section .col-md-4 {
                flex: 0 0 100%;
                max-width: 100%;
            }
            
            /* Testimonials in full width */
            .testimonials-section .col-md-6 {
                flex: 0 0 100%;
                max-width: 100%;
            }
            
            /* Center text on mobile */
            .row.align-items-center {
                text-align: center;
            }
            
            /* Better badge wrapping */
            .text-center {
                padding: 0 10px;
            }
        }
        
        /* Fix for very small screens */
        @media (max-width: 380px) {
            .camera-grid {
                gap: 5px;
            }
            
            .camera-item {
                padding: 10px 5px;
            }
            
            .camera-icon {
                font-size: 1.5rem;
            }
            
            .camera-item h6 {
                font-size: 0.7rem;
            }
            
            .security-badge {
                padding: 5px 10px;
                font-size: 0.8rem;
            }
            
            .package-badge {
                font-size: 8px;
                padding: 2px 25px;
                right: -25px;
            }
        }
        
        /* Fix for notched phones */
        @supports (padding: max(0px)) {
            .container {
                padding-left: max(20px, env(safe-area-inset-left));
                padding-right: max(20px, env(safe-area-inset-right));
            }
        }
        
        /* Reduced motion preferences */
        @media (prefers-reduced-motion: reduce) {
            .page-hero::before,
            .stats-card::after,
            .feed-indicator,
            .tech-item,
            .camera-item,
            .feature-card,
            .package-card,
            .stats-card,
            .camera-feed,
            .btn {
                animation: none;
                transition: none;
            }
            
            .page-hero::before,
            .stats-card::after {
                animation: none;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/header'); %>
    <%- include('../partials/floating-buttons'); %>

    <!-- Hero Section -->
    <section class="page-hero">
        <div class="container position-relative">
            <div class="row align-items-center">
                <div class="col-lg-6" data-aos="fade-right">
                    <h1 class="display-3 fw-bold mb-4 text-white">CCTV & Security Systems</h1>
                    <p class="lead mb-4 text-white">Advanced surveillance solutions to protect what matters most. High-definition cameras, intelligent analytics, and 24/7 monitoring.</p>
                    <div class="d-flex flex-column flex-sm-row gap-3">
                        <a href="/contact" class="btn btn-light btn-lg px-5 py-3">Free Security Audit</a>
                        <a href="#features" class="btn btn-outline-light btn-lg px-5 py-3">Explore Solutions</a>
                    </div>
                </div>
                <div class="col-lg-6" data-aos="fade-left">
                    <div class="camera-grid">
                        <div class="camera-item">
                            <i class="bi bi-camera-video camera-icon"></i>
                            <h6>Dome</h6>
                        </div>
                        <div class="camera-item">
                            <i class="bi bi-camera-reels camera-icon"></i>
                            <h6>Bullet</h6>
                        </div>
                        <div class="camera-item">
                            <i class="bi bi-camera camera-icon"></i>
                            <h6>PTZ</h6>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="py-5" id="features">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">Comprehensive Security Solutions</h2>
            <div class="row g-4">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-camera-video"></i>
                        </div>
                        <h4 class="fw-bold mb-3">HD CCTV Cameras</h4>
                        <p class="text-muted">4K Ultra HD cameras with night vision, wide dynamic range, and weatherproof housing for indoor and outdoor use.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Access Control</h4>
                        <p class="text-muted">Biometric, RFID, and keypad access systems with centralized management and audit trails.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-bell"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Intrusion Detection</h4>
                        <p class="text-muted">Motion sensors, glass break detectors, and alarm systems with instant notifications.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="400">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-cloud"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Cloud Storage</h4>
                        <p class="text-muted">Secure cloud backup with 30-day retention and easy access to footage from anywhere.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="500">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-phone"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Mobile Monitoring</h4>
                        <p class="text-muted">Watch live feeds and playback recordings from your smartphone or tablet anytime.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="600">
                    <div class="feature-card">
                        <div class="feature-icon">
