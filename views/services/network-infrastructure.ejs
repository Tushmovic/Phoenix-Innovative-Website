<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
    <style>
        .page-hero {
            background: linear-gradient(135deg, #4361EE, #3A0CA3, #2EC4B6);
            color: white;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }
        
        .page-hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 60%);
            animation: rotate 30s linear infinite;
        }
        
        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        .service-detail-image {
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            transition: all 0.5s ease;
        }
        
        .service-detail-image:hover {
            transform: scale(1.02) rotate(1deg);
            box-shadow: 0 30px 60px rgba(67,97,238,0.3);
        }
        
        .service-detail-image:active {
            transform: scale(1.01);
        }
        
        .feature-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            height: 100%;
            border-bottom: 4px solid transparent;
        }
        
        .feature-card:hover {
            transform: translateY(-10px);
            border-bottom-color: #4361EE;
            box-shadow: 0 20px 40px rgba(67,97,238,0.15);
        }
        
        .feature-card:active {
            transform: translateY(-5px);
        }
        
        .feature-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #4361EE, #3A0CA3);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            color: white;
            font-size: 28px;
        }
        
        .network-diagram {
            background: #f8f9fa;
            padding: 40px;
            border-radius: 20px;
            position: relative;
            overflow: hidden;
        }
        
        .network-node {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #4361EE, #3A0CA3);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            margin: 0 auto 20px;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(67,97,238,0.7); }
            70% { box-shadow: 0 0 0 20px rgba(67,97,238,0); }
            100% { box-shadow: 0 0 0 0 rgba(67,97,238,0); }
        }
        
        .connection-line {
            height: 2px;
            background: linear-gradient(90deg, #4361EE, #2EC4B6);
            margin: 20px 0;
            position: relative;
        }
        
        .tech-badge {
            display: inline-block;
            padding: 8px 20px;
            background: linear-gradient(135deg, #4361EE, #3A0CA3);
            color: white;
            border-radius: 30px;
            margin: 5px;
            font-weight: 500;
            transition: all 0.3s ease;
            -webkit-tap-highlight-color: transparent;
        }
        
        .tech-badge:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 10px 20px rgba(67,97,238,0.3);
        }
        
        .tech-badge:active {
            transform: scale(0.95);
        }
        
        .package-card {
            background: white;
            padding: 40px 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            height: 100%;
            position: relative;
            overflow: hidden;
        }
        
        .package-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 30px 50px rgba(67,97,238,0.2);
        }
        
        .package-card:active {
            transform: translateY(-5px);
        }
        
        .package-card.popular::before {
            content: 'MOST POPULAR';
            position: absolute;
            top: 20px;
            right: -35px;
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            color: white;
            padding: 5px 40px;
            transform: rotate(45deg);
            font-size: 12px;
            font-weight: bold;
        }
        
        .package-price {
            font-size: 3rem;
            font-weight: 800;
            color: #4361EE;
            margin-bottom: 20px;
        }
        
        .package-price small {
            font-size: 1rem;
            color: #6c757d;
        }
        
        .stats-card {
            background: linear-gradient(135deg, #4361EE, #3A0CA3);
            color: white;
            padding: 40px 20px;
            border-radius: 15px;
            text-align: center;
            transition: all 0.3s ease;
        }
        
        .stats-card:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 20px 40px rgba(67,97,238,0.3);
        }
        
        .stats-card:active {
            transform: scale(0.98);
        }
        
        .stats-number {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 10px;
            color: white;
        }
        
        .cta-section {
            background: linear-gradient(135deg, #2EC4B6, #4361EE);
            color: white;
            padding: 80px 0;
            position: relative;
            overflow: hidden;
        }
        
        .btn-light {
            background: white;
            color: #333;
            border: none;
            padding: 15px 30px;
            font-weight: 600;
            border-radius: 8px;
            -webkit-tap-highlight-color: transparent;
        }
        
        .btn-outline-light {
            background: transparent;
            border: 2px solid white;
            color: white;
            padding: 15px 30px;
            font-weight: 600;
            border-radius: 8px;
            -webkit-tap-highlight-color: transparent;
        }
        
        .btn-light:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(255,255,255,0.3);
        }
        
        .btn-light:active {
            transform: scale(0.95);
        }
        
        .btn-outline-light:hover {
            background: white;
            color: #333;
        }
        
        .btn-outline-light:active {
            transform: scale(0.95);
        }
        
        /* ===== MOBILE RESPONSIVE OPTIMIZATIONS ===== */
        
        /* Extra small devices (phones, 576px and down) */
        @media (max-width: 576px) {
            .page-hero {
                padding: 100px 0 60px;
            }
            
            .page-hero h1 {
                font-size: 2.2rem !important;
            }
            
            .page-hero p {
                font-size: 1rem !important;
            }
            
            .page-hero .d-flex {
                flex-direction: column;
                gap: 10px !important;
            }
            
            .page-hero .btn {
                width: 100%;
                padding: 12px !important;
                font-size: 1rem !important;
            }
            
            .service-detail-image {
                margin-top: 30px;
            }
            
            .feature-card {
                padding: 25px 20px;
            }
            
            .feature-card h4 {
                font-size: 1.2rem !important;
            }
            
            .feature-card p {
                font-size: 0.95rem !important;
            }
            
            .feature-icon {
                width: 60px;
                height: 60px;
                font-size: 24px;
            }
            
            .network-diagram {
                padding: 20px;
                margin-top: 30px;
            }
            
            .network-node {
                width: 50px;
                height: 50px;
                font-size: 0.9rem;
            }
            
            .network-node i {
                font-size: 1.2rem;
            }
            
            .network-diagram small {
                font-size: 0.8rem;
            }
            
            .tech-badge {
                padding: 6px 15px;
                font-size: 0.9rem;
                margin: 3px;
            }
            
            .stats-card {
                padding: 25px 15px;
            }
            
            .stats-number {
                font-size: 2rem !important;
            }
            
            .stats-card p {
                font-size: 0.9rem !important;
            }
            
            .package-card {
                padding: 30px 20px;
            }
            
            .package-price {
                font-size: 2rem !important;
            }
            
            .package-price small {
                font-size: 0.9rem;
            }
            
            .package-card.popular::before {
                font-size: 10px;
                padding: 3px 30px;
                right: -30px;
            }
            
            .cta-section {
                padding: 60px 0 !important;
            }
            
            .cta-section h2 {
                font-size: 1.8rem !important;
            }
            
            .cta-section p {
                font-size: 1rem !important;
            }
            
            .cta-section .d-flex {
                flex-direction: column;
                gap: 10px !important;
            }
            
            .cta-section .btn {
                width: 100%;
                padding: 12px !important;
                font-size: 1rem !important;
            }
            
            /* Overview section adjustments */
            .overview-section .col-6 {
                flex: 0 0 100%;
                max-width: 100%;
                margin-bottom: 10px;
            }
        }
        
        /* Small devices (landscape phones, 577px to 767px) */
        @media (min-width: 577px) and (max-width: 767px) {
            .page-hero h1 {
                font-size: 2.5rem !important;
            }
            
            .feature-card h4 {
                font-size: 1.2rem !important;
            }
            
            .stats-number {
                font-size: 2.2rem !important;
            }
            
            .package-price {
                font-size: 2.5rem !important;
            }
            
            .cta-section h2 {
                font-size: 2rem !important;
            }
        }
        
        /* Medium devices (tablets, 768px to 991px) */
        @media (min-width: 768px) and (max-width: 991px) {
            .feature-card h4 {
                font-size: 1.2rem !important;
            }
            
            .stats-number {
                font-size: 2.5rem !important;
            }
        }
        
        /* Touch target optimization for mobile */
        @media (max-width: 768px) {
            .btn,
            .btn-light,
            .btn-outline-light,
            .tech-badge {
                min-height: 44px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }
            
            /* Remove hover effects on mobile */
            .service-detail-image:hover {
                transform: none;
            }
            
            .service-detail-image:active {
                transform: scale(1.01);
            }
            
            .feature-card:hover {
                transform: none;
            }
            
            .feature-card:active {
                transform: translateY(-5px);
            }
            
            .package-card:hover {
                transform: none;
            }
            
            .package-card:active {
                transform: translateY(-5px);
            }
            
            .stats-card:hover {
                transform: none;
            }
            
            .stats-card:active {
                transform: scale(0.98);
            }
            
            .tech-badge:hover {
                transform: none;
            }
            
            .tech-badge:active {
                transform: scale(0.95);
            }
            
            /* Improve spacing */
            .container {
                padding-left: 20px;
                padding-right: 20px;
            }
            
            /* Fix any horizontal scrolling */
            body {
                overflow-x: hidden;
                width: 100%;
            }
            
            /* Better grid for stats */
            .row.g-4 {
                --bs-gutter-y: 1rem;
            }
            
            /* Stats in 2 columns on mobile */
            .stats-section .col-md-3 {
                flex: 0 0 50%;
                max-width: 50%;
            }
            
            /* Features in full width on mobile */
            .features-section .col-md-4 {
                flex: 0 0 100%;
                max-width: 100%;
            }
            
            /* Center align on mobile */
            .row.align-items-center {
                text-align: center;
            }
            
            /* Network diagram adjustments */
            .network-diagram .col-4,
            .network-diagram .col-3 {
                padding: 0 5px;
            }
            
            .network-diagram .network-node {
                margin: 0 auto 10px;
            }
        }
        
        /* Fix for very small screens */
        @media (max-width: 380px) {
            .network-diagram .col-4,
            .network-diagram .col-3 {
                flex: 0 0 50%;
                max-width: 50%;
                margin-bottom: 15px;
            }
            
            .network-diagram .row:first-child .col-4 {
                flex: 0 0 33.333%;
                max-width: 33.333%;
            }
            
            .tech-badge {
                padding: 4px 10px;
                font-size: 0.8rem;
            }
            
            .package-card.popular::before {
                font-size: 8px;
                padding: 2px 25px;
                right: -25px;
            }
        }
        
        /* Fix for notched phones */
        @supports (padding: max(0px)) {
            .container {
                padding-left: max(20px, env(safe-area-inset-left));
                padding-right: max(20px, env(safe-area-inset-right));
            }
        }
        
        /* Reduced motion preferences */
        @media (prefers-reduced-motion: reduce) {
            .page-hero::before,
            .service-detail-image,
            .feature-card,
            .network-node,
            .package-card,
            .stats-card,
            .tech-badge,
            .btn,
            .btn-light,
            .btn-outline-light {
                animation: none;
                transition: none;
            }
            
            .page-hero::before,
            .network-node {
                animation: none;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/header'); %>
    <%- include('../partials/floating-buttons'); %>

    <!-- Hero Section -->
    <section class="page-hero">
        <div class="container position-relative">
            <div class="row align-items-center">
                <div class="col-lg-6" data-aos="fade-right">
                    <h1 class="display-3 fw-bold mb-4">Network Infrastructure Solutions</h1>
                    <p class="lead mb-4">Build a robust, scalable, and secure network foundation for your business. From structured cabling to enterprise-grade networking equipment.</p>
                    <div class="d-flex flex-column flex-sm-row gap-3">
                        <a href="/contact" class="btn btn-light btn-lg px-5 py-3">Get Free Consultation</a>
                        <a href="#learn-more" class="btn btn-outline-light btn-lg px-5 py-3">Learn More</a>
                    </div>
                </div>
                <div class="col-lg-6" data-aos="fade-left">
                    <div class="service-detail-image">
                        <img src="/images/Networking BANNER 1.webp" alt="Network Infrastructure" class="img-fluid">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Overview Section -->
    <section class="py-5" id="learn-more">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6" data-aos="fade-right">
                    <h2 class="display-5 fw-bold mb-4">The Backbone of Your Digital Success</h2>
                    <p class="lead mb-4">In today's connected world, your network is the lifeline of your business. We design and implement future-proof network infrastructure that ensures reliability, security, and scalability.</p>
                    <div class="row g-4">
                        <div class="col-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-4"></i>
                                <span>99.9% Uptime</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-4"></i>
                                <span>Enterprise Security</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-4"></i>
                                <span>Scalable</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-4"></i>
                                <span>24/7 Monitoring</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6" data-aos="fade-left">
                    <div class="network-diagram">
                        <div class="row text-center">
                            <div class="col-4">
                                <div class="network-node"><i class="bi bi-router"></i></div>
                                <small>Core Switch</small>
                            </div>
                            <div class="col-4">
                                <div class="network-node"><i class="bi bi-hdd-stack"></i></div>
                                <small>Servers</small>
                            </div>
                            <div class="col-4">
                                <div class="network-node"><i class="bi bi-shield-lock"></i></div>
                                <small>Firewall</small>
                            </div>
                        </div>
                        <div class="connection-line"></div>
                        <div class="row text-center">
                            <div class="col-3">
                                <div class="network-node" style="width: 50px; height: 50px;"><i class="bi bi-laptop"></i></div>
                                <small>Workstation</small>
                            </div>
                            <div class="col-3">
                                <div class="network-node" style="width: 50px; height: 50px;"><i class="bi bi-phone"></i></div>
                                <small>Mobile</small>
                            </div>
                            <div class="col-3">
                                <div class="network-node" style="width: 50px; height: 50px;"><i class="bi bi-printer"></i></div>
                                <small>Printers</small>
                            </div>
                            <div class="col-3">
                                <div class="network-node" style="width: 50px; height: 50px;"><i class="bi bi-camera"></i></div>
                                <small>IP Cameras</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="py-5 bg-light">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">Comprehensive Network Solutions</h2>
            <div class="row g-4">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-diagram-3"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Structured Cabling</h4>
                        <p class="text-muted">Category 6A and Fiber Optic cabling solutions for high-speed, reliable connectivity throughout your facility.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-router"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Enterprise Routing</h4>
                        <p class="text-muted">Cisco and MikroTik enterprise-grade equipment for optimal network performance and traffic management.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-wifi"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Wireless Solutions</h4>
                        <p class="text-muted">Enterprise WiFi 6 and 6E deployments for seamless, high-speed wireless coverage across your premises.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="400">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Network Security</h4>
                        <p class="text-muted">Next-gen firewalls, VPN solutions, and intrusion prevention systems to protect your digital assets.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="500">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-hdd-stack"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Server Infrastructure</h4>
                        <p class="text-muted">On-premise and hybrid server setups with virtualization capabilities for maximum efficiency.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="600">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-cloud"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Cloud Integration</h4>
                        <p class="text-muted">Seamless integration with major cloud platforms including AWS, Azure, and Google Cloud.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Technologies Section -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center display-5 fw-bold mb-5" data-aos="fade-up">Technologies We Work With</h2>
            <div class="text-center mb-5">
                <span class="tech-badge">Cisco</span>
                <span class="tech-badge">MikroTik</span>
                <span class="tech-badge">Ubiquiti</span>
                <span class="tech-badge">TP-Link</span>
                <span class="tech-badge">D-Link</span>
                <span class="tech-badge">HP Aruba</span>
                <span class="tech-badge">Fortinet</span>
                <span class="tech-badge">Palo Alto</span>
                <span class="tech-badge">VMware</span>
                <span class="tech-badge">Microsoft</span>
                <span class="tech-badge">Linux</span>
                <span class="tech-badge">AWS</span>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row g-4">
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="100">
                    <div class="stats-card">
                        <div class="stats-number counter-value" data-target="200">0</div>
                        <p class="mb-0">Networks Deployed</p>
                    </div>
                </div>
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="200">
                    <div class="stats-card" style="background: linear-gradient(135deg, #2EC4B6, #4361EE);">
                        <div class="stats-number counter-value" data-target="99.9">0</div>
                        <p class="mb-0">Uptime %</p>
                    </div>
                </div>
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="300">
                    <div class="stats-card" style="background: linear-gradient(135deg, #FF9F1C, #FF6B35);">
                        <div class="stats-number counter-value" data-target="24">0</div>
                        <p class="mb-0">Support (hrs)</p>
                    </div>
                </div>
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="400">
                    <div class="stats-card" style="background: linear-gradient(135deg, #3A0CA3, #4361EE);">
                        <div class="stats-number counter-value" data-target="5000">0</div>
                        <p class="mb-0">Devices Managed</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container position-relative">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8">
                    <h2 class="display-4 fw-bold mb-4" data-aos="fade-up">Ready to Build Your Network?</h2>
                    <p class="lead mb-5" data-aos="fade-up" data-aos-delay="100">Get a free network assessment and quote today. Our experts will design the perfect solution for your business.</p>
                    <div class="d-flex flex-column flex-sm-row justify-content-center gap-3" data-aos="fade-up" data-aos-delay="200">
                        <a href="/contact" class="btn btn-light btn-lg px-5 py-3">Get Free Assessment</a>
                        <a href="tel:+2349135926075" class="btn btn-outline-light btn-lg px-5 py-3">Call Us Now</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('../partials/footer'); %>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="/js/animations.js"></script>
    <script src="/js/transitions.js"></script>
    <script>
        AOS.init({
            duration: 1000,
            once: true,
            offset: 100
        });

        // Counter animation
        function animateCounter(element, target) {
            let current = 0;
            const increment = target / 50;
            const timer = setInterval(() => {
                current += increment;
                if (current >= target) {
                    element.textContent = target;
                    clearInterval(timer);
                } else {
                    element.textContent = Math.floor(current);
                }
            }, 20);
        }

        const counters = document.querySelectorAll('.counter-value');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const target = parseFloat(entry.target.dataset.target);
                    animateCounter(entry.target, target);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        counters.forEach(counter => observer.observe(counter));
    </script>
</body>
</html>