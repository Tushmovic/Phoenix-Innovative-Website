<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
    <style>
        .page-hero {
            background: linear-gradient(135deg, #4361EE, #3A0CA3, #2EC4B6);
            color: white;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }
        
        .page-hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 60%);
            animation: rotate 30s linear infinite;
        }
        
        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        .service-detail-image {
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            transition: all 0.5s ease;
        }
        
        .service-detail-image:hover {
            transform: scale(1.02) rotate(1deg);
            box-shadow: 0 30px 60px rgba(67,97,238,0.3);
        }
        
        .feature-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            height: 100%;
            border-bottom: 4px solid transparent;
        }
        
        .feature-card:hover {
            transform: translateY(-10px);
            border-bottom-color: #4361EE;
            box-shadow: 0 20px 40px rgba(67,97,238,0.15);
        }
        
        .feature-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #4361EE, #3A0CA3);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            color: white;
            font-size: 28px;
        }
        
        .network-diagram {
            background: #f8f9fa;
            padding: 40px;
            border-radius: 20px;
            position: relative;
            overflow: hidden;
        }
        
        .network-node {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #4361EE, #3A0CA3);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            margin: 0 auto 20px;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(67,97,238,0.7); }
            70% { box-shadow: 0 0 0 20px rgba(67,97,238,0); }
            100% { box-shadow: 0 0 0 0 rgba(67,97,238,0); }
        }
        
        .connection-line {
            height: 2px;
            background: linear-gradient(90deg, #4361EE, #2EC4B6);
            margin: 20px 0;
            position: relative;
        }
        
        .tech-badge {
            display: inline-block;
            padding: 8px 20px;
            background: linear-gradient(135deg, #4361EE, #3A0CA3);
            color: white;
            border-radius: 30px;
            margin: 5px;
            font-weight: 500;
            transition: all 0.3s ease;
        }
        
        .tech-badge:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 10px 20px rgba(67,97,238,0.3);
        }
        
        .package-card {
            background: white;
            padding: 40px 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            height: 100%;
            position: relative;
            overflow: hidden;
        }
        
        .package-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 30px 50px rgba(67,97,238,0.2);
        }
        
        .package-card.popular::before {
            content: 'MOST POPULAR';
            position: absolute;
            top: 20px;
            right: -35px;
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            color: white;
            padding: 5px 40px;
            transform: rotate(45deg);
            font-size: 12px;
            font-weight: bold;
        }
        
        .package-price {
            font-size: 3rem;
            font-weight: 800;
            color: #4361EE;
            margin-bottom: 20px;
        }
        
        .package-price small {
            font-size: 1rem;
            color: #6c757d;
        }
        
        .stats-card {
            background: linear-gradient(135deg, #4361EE, #3A0CA3);
            color: white;
            padding: 40px 20px;
            border-radius: 15px;
            text-align: center;
            transition: all 0.3s ease;
        }
        
        .stats-card:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 20px 40px rgba(67,97,238,0.3);
        }
        
        .stats-number {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 10px;
        }
        
        .cta-section {
            background: linear-gradient(135deg, #2EC4B6, #4361EE);
            color: white;
            padding: 80px 0;
            position: relative;
            overflow: hidden;
        }
    </style>
</head>
<body>
