<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
    <style>
        .page-hero {
            background: linear-gradient(135deg, #2EC4B6, #4361EE, #3A0CA3);
            color: white;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }
        
        .page-hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 60%);
            animation: rotate 30s linear infinite;
        }
        
        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        .speed-meter {
            width: 200px;
            height: 200px;
            margin: 0 auto;
            position: relative;
        }
        
        .speed-meter svg {
            transform: rotate(-90deg);
        }
        
        .speed-meter circle {
            fill: none;
            stroke-width: 8;
            stroke-linecap: round;
        }
        
        .speed-meter .bg-circle {
            stroke: rgba(255,255,255,0.2);
        }
        
        .speed-meter .progress-circle {
            stroke: white;
            stroke-dasharray: 502;
            stroke-dashoffset: calc(502 - (502 * 0.8));
            transition: stroke-dashoffset 1s ease;
        }
        
        .speed-value {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 3rem;
            font-weight: 800;
            text-align: center;
            color: white;
        }
        
        .speed-value small {
            font-size: 1rem;
            display: block;
            color: rgba(255,255,255,0.8);
        }
        
        .package-card {
            background: white;
            padding: 40px 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            height: 100%;
            position: relative;
            overflow: hidden;
        }
        
        .package-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 30px 50px rgba(46,196,182,0.2);
        }
        
        .package-card.popular::before {
            content: 'BEST VALUE';
            position: absolute;
            top: 20px;
            right: -35px;
            background: linear-gradient(135deg, #2EC4B6, #4361EE);
            color: white;
            padding: 5px 40px;
            transform: rotate(45deg);
            font-size: 12px;
            font-weight: bold;
        }
        
        .package-name {
            font-size: 2rem;
            font-weight: 800;
            color: #2EC4B6;
            margin-bottom: 20px;
        }
        
        .package-price {
            font-size: 3rem;
            font-weight: 800;
            color: #333;
            margin-bottom: 20px;
        }
        
        .package-price small {
            font-size: 1rem;
            color: #6c757d;
        }
        
        .package-features {
            list-style: none;
            padding: 0;
            margin: 20px 0;
        }
        
        .package-features li {
            padding: 10px 0;
            border-bottom: 1px solid #eee;
            color: #333;
        }
        
        .package-features li i {
            color: #2EC4B6;
            margin-right: 10px;
        }
        
        .feature-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            height: 100%;
            text-align: center;
        }
        
        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(46,196,182,0.15);
        }
        
        .feature-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #2EC4B6, #4361EE);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: white;
            font-size: 32px;
        }
        
        .coverage-map {
            background: #f8f9fa;
            padding: 40px;
            border-radius: 20px;
        }
        
        .stats-card {
            background: linear-gradient(135deg, #2EC4B6, #4361EE);
            color: white;
            padding: 40px 20px;
            border-radius: 15px;
            text-align: center;
            transition: all 0.3s ease;
        }
        
        .stats-card:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 20px 40px rgba(46,196,182,0.3);
        }
        
        .stats-number {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 10px;
            color: white;
        }
        
        .testimonial-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            margin: 20px 0;
        }
        
        .speed-test {
            background: #f8f9fa;
            padding: 40px;
            border-radius: 20px;
            text-align: center;
        }
        
        .speed-result {
            font-size: 4rem;
            font-weight: 800;
            color: #2EC4B6;
            margin: 20px 0;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #2EC4B6, #4361EE);
            border: none;
            color: white;
            padding: 15px 40px;
            font-size: 1.2rem;
            border-radius: 50px;
        }
        
        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(46,196,182,0.4);
        }
        
        .btn-outline-primary {
            color: #2EC4B6;
            border: 2px solid #2EC4B6;
            background: transparent;
            padding: 12px 20px;
            font-weight: 600;
            border-radius: 8px;
        }
        
        .btn-outline-primary:hover {
            background: #2EC4B6;
            color: white;
        }
        
        .btn-warning {
            background: #FF6B35;
            border: none;
            color: white;
            padding: 12px 20px;
            font-weight: 600;
            border-radius: 8px;
        }
        
        .btn-warning:hover {
            background: #e55a2b;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255,107,53,0.3);
        }
        
        .btn-light {
            background: white;
            border: none;
            color: #333;
            padding: 15px 30px;
            font-weight: 600;
            border-radius: 8px;
        }
        
        .btn-outline-light {
            background: transparent;
            border: 2px solid white;
            color: white;
            padding: 15px 30px;
            font-weight: 600;
            border-radius: 8px;
        }
        
        .btn-outline-light:hover {
            background: white;
            color: #333;
        }
        
        .cta-section {
            background: linear-gradient(135deg, #2EC4B6, #4361EE);
            color: white;
            padding: 80px 0;
        }
        
        h2.display-5 {
            color: #333;
            font-size: 2.8rem;
            font-weight: 800;
            margin-bottom: 3rem;
        }
        
        .bg-light {
            background-color: #f8f9fa;
        }
        
        .text-success {
            color: #28a745 !important;
        }
        
        .text-warning {
            color: #ffc107 !important;
        }
        
        .text-danger {
            color: #dc3545 !important;
        }
        
        @media (max-width: 768px) {
            .package-card.popular {
                transform: scale(1);
            }
        }
    </style>
</head>
