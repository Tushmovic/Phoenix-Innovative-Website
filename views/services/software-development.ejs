<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
    <style>
        /* Hero Section */
        .page-hero {
            background: linear-gradient(135deg, #FF9F1C, #FF6B35, #E71D36);
            color: white;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }
        
        .page-hero h1 {
            color: white;
            font-size: 3.5rem;
            font-weight: 800;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        .page-hero p {
            color: rgba(255,255,255,0.95);
        }
        
        .page-hero .btn-light {
            background: white;
            color: #333;
            border: none;
            padding: 15px 30px;
            font-weight: 600;
            border-radius: 8px;
        }
        
        .page-hero .btn-outline-light {
            background: transparent;
            border: 2px solid white;
            color: white;
            padding: 15px 30px;
            font-weight: 600;
            border-radius: 8px;
        }
        
        .page-hero .btn-outline-light:hover {
            background: white;
            color: #333;
        }
        
        /* Code Window */
        .code-window {
            background: #1e1e2f;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }
        
        .code-header {
            background: #2d2d3f;
            padding: 15px;
            display: flex;
            gap: 8px;
        }
        
        .code-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
        }
        
        .code-dot.red { background: #ff5f56; }
        .code-dot.yellow { background: #ffbd2e; }
        .code-dot.green { background: #27c93f; }
        
        .code-content {
            padding: 20px;
            color: #fff;
            font-family: 'Courier New', monospace;
            font-size: 14px;
        }
        
        .code-line {
            margin-bottom: 10px;
            color: #fff;
        }
        
        .code-keyword { color: #ff79c6; }
        .code-function { color: #50fa7b; }
        .code-string { color: #f1fa8c; }
        
        /* Service Cards */
        .service-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            height: 100%;
        }
        
        .service-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(255,107,53,0.15);
        }
        
        .service-card h4 {
            color: #333;
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 15px;
        }
        
        .service-card p {
            color: #666;
            line-height: 1.6;
        }
        
        .service-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #FF6B35, #FF9F1C);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            color: white;
            font-size: 28px;
        }
        
        /* Tech Stack Items */
        .tech-stack-item {
            background: white;
            padding: 30px 20px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            text-align: center;
            transition: all 0.3s ease;
            height: 100%;
        }
        
        .tech-stack-item:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 20px 40px rgba(255,107,53,0.2);
        }
        
        .tech-stack-item i {
            font-size: 3rem;
            color: #FF6B35;
            margin-bottom: 15px;
        }
        
        .tech-stack-item h6 {
            color: #333;
            font-size: 1.1rem;
            font-weight: 600;
        }
        
        /* Timeline */
        .process-timeline {
            position: relative;
            padding: 40px 0;
        }
        
        .process-timeline::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            width: 2px;
            height: 100%;
            background: linear-gradient(180deg, #FF6B35, #4361EE);
            transform: translateX(-50%);
        }
        
        .timeline-item {
            position: relative;
            margin-bottom: 60px;
            width: 50%;
        }
        
        .timeline-item:nth-child(odd) {
            left: 0;
            padding-right: 40px;
        }
        
        .timeline-item:nth-child(even) {
            left: 50%;
            padding-left: 40px;
        }
        
        .timeline-content {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            position: relative;
        }
        
        .timeline-content::before {
            content: '';
            position: absolute;
            top: 20px;
            width: 20px;
            height: 20px;
            background: #FF6B35;
            border-radius: 50%;
        }
        
        .timeline-item:nth-child(odd) .timeline-content::before {
            right: -50px;
        }
        
        .timeline-item:nth-child(even) .timeline-content::before {
            left: -50px;
        }
        
        .timeline-date {
            position: absolute;
            top: 15px;
            right: 20px;
            color: #FF6B35;
            font-weight: bold;
        }
        
        .timeline-content h4 {
            color: #333;
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 10px;
        }
        
        .timeline-content p {
            color: #666;
        }
        
        /* Stats Cards */
        .stats-card {
            background: linear-gradient(135deg, #FF6B35, #FF9F1C);
            color: white;
            padding: 40px 20px;
            border-radius: 15px;
            text-align: center;
            transition: all 0.3s ease;
        }
        
        .stats-card:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 20px 40px rgba(255,107,53,0.3);
        }
        
        .stats-number {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 10px;
            color: white;
        }
        
        .stats-card p {
            color: rgba(255,255,255,0.95);
            font-size: 1.1rem;
        }
        
        /* Project Cards */
        .project-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            height: 100%;
        }
        
        .project-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 30px 50px rgba(255,107,53,0.2);
        }
        
        .project-image {
            height: 200px;
            overflow: hidden;
        }
        
        .project-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: all 0.5s ease;
        }
        
        .project-card:hover .project-image img {
            transform: scale(1.1);
        }
        
        .project-content {
            padding: 20px;
        }
        
        .project-content h4 {
            color: #333;
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 10px;
        }
        
        .project-content p {
            color: #666;
        }
        
        .tech-badge {
            display: inline-block;
            padding: 5px 12px;
            background: #f0f0f0;
            border-radius: 20px;
            font-size: 12px;
            margin: 2px;
            color: #666;
        }
        
        /* Testimonial Cards */
        .testimonial-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            margin: 20px 0;
            position: relative;
        }
        
        .testimonial-card p {
            color: #333;
            font-size: 1rem;
            line-height: 1.6;
            margin-bottom: 15px;
        }
        
        .testimonial-card h6 {
            color: #333;
            font-weight: 700;
        }
        
        .testimonial-card small {
            color: #666;
        }
        
        .client-image {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #FF6B35;
        }
        
        /* CTA Section */
        .cta-section {
            background: linear-gradient(135deg, #FF6B35, #4361EE);
            color: white;
            padding: 80px 0;
            position: relative;
            overflow: hidden;
        }
        
        .cta-section h2 {
            color: white;
            font-size: 3rem;
            font-weight: 800;
        }
        
        .cta-section p {
            color: rgba(255,255,255,0.95);
            font-size: 1.3rem;
        }
        
        .cta-section .btn-light {
            background: white;
            color: #333;
            border: none;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 8px;
        }
        
        .cta-section .btn-outline-light {
            background: transparent;
            border: 2px solid white;
            color: white;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 8px;
        }
        
        .cta-section .btn-outline-light:hover {
            background: white;
            color: #333;
        }
        
        .floating-shape {
            position: absolute;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            animation: float 6s ease-in-out infinite;
        }
        
        @keyframes float {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            33% { transform: translate(20px, -20px) rotate(120deg); }
            66% { transform: translate(-20px, 20px) rotate(240deg); }
        }
        
        /* Section Headers */
        h2.display-5 {
            color: #333;
            font-size: 2.8rem;
            font-weight: 800;
            margin-bottom: 3rem;
        }
        
        .bg-light {
            background-color: #f8f9fa;
        }
        
        .text-muted {
            color: #666 !important;
        }
        
        @media (max-width: 768px) {
            .page-hero h1 {
                font-size: 2.5rem;
            }
            
            h2.display-5 {
                font-size: 2.2rem;
            }
            
            .timeline-item {
                width: 100%;
                left: 0 !important;
                padding: 0 !important;
                margin-bottom: 30px;
            }
            
            .process-timeline::before {
                left: 30px;
            }
            
            .timeline-content::before {
                display: none;
            }
        }
    </style>
</head>
