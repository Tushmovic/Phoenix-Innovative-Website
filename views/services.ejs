<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
    <style>
        .page-hero {
            background: linear-gradient(135deg, #4361EE, #3A0CA3, #2EC4B6);
            color: white;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }
        
        .page-hero h1 {
            color: white;
            font-size: 3.5rem;
            font-weight: 800;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        .page-hero p {
            color: rgba(255,255,255,0.95);
            font-size: 1.3rem;
        }
        
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 30px;
            margin: 50px 0;
        }
        
        .service-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            height: 100%;
            position: relative;
        }
        
        .service-card:hover {
            transform: translateY(-20px) scale(1.02);
            box-shadow: 0 30px 50px rgba(67,97,238,0.2);
        }
        
        .service-image {
            height: 250px;
            overflow: hidden;
            position: relative;
        }
        
        .service-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: all 0.8s ease;
        }
        
        .service-card:hover .service-image img {
            transform: scale(1.1) rotate(2deg);
        }
        
        /* Make the entire overlay a clickable link */
        .service-overlay-link {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            z-index: 2;
        }
        
        .service-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(255,107,53,0.8), rgba(67,97,238,0.8));
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: all 0.4s ease;
            width: 100%;
            height: 100%;
        }
        
        .service-card:hover .service-overlay {
            opacity: 1;
        }
        
        .service-overlay span {
            color: white;
            font-size: 1.2rem;
            font-weight: 700;
            padding: 12px 25px;
            background: rgba(255,255,255,0.2);
            border-radius: 50px;
            backdrop-filter: blur(5px);
            transform: translateY(20px);
            transition: all 0.4s ease;
            pointer-events: none; /* Prevents span from blocking click */
        }
        
        .service-card:hover .service-overlay span {
            transform: translateY(0);
        }
        
        .service-content {
            padding: 30px;
        }
        
        .service-content h3 {
            color: #333;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 15px;
            transition: color 0.3s ease;
        }
        
        .service-card:hover .service-content h3 {
            color: #FF6B35;
        }
        
        .service-content p {
            color: #666;
            line-height: 1.6;
            margin-bottom: 20px;
        }
        
        .service-btn {
            display: inline-block;
            padding: 12px 30px;
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            position: relative;
            overflow: hidden;
            z-index: 3;
            cursor: pointer;
            -webkit-tap-highlight-color: transparent;
        }
        
        .service-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s;
        }
        
        .service-btn:hover::before {
            left: 100%;
        }
        
        .service-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(255,107,53,0.3);
        }
        
        .service-btn:active {
            transform: scale(0.95);
        }
        
        .stats-section {
            background: linear-gradient(135deg, #f8f9fa, white);
            padding: 60px 0;
        }
        
        .stat-item {
            text-align: center;
            padding: 30px;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
        }
        
        .stat-item:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(67,97,238,0.1);
        }
        
        .stat-number {
            font-size: 3rem;
            font-weight: 800;
            color: #FF6B35;
            margin-bottom: 10px;
        }
        
        .stat-label {
            color: #333;
            font-size: 1.1rem;
            font-weight: 600;
        }
        
        .cta-section {
            background: linear-gradient(135deg, #FF6B35, #4361EE);
            color: white;
            padding: 80px 0;
            position: relative;
            overflow: hidden;
        }
        
        .cta-section::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2), transparent);
            animation: rotate 30s linear infinite;
        }
        
        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        .cta-section h2 {
            color: white;
            font-size: 2.8rem;
            font-weight: 800;
        }
        
        .cta-section p {
            color: rgba(255,255,255,0.95);
        }
        
        .cta-section .btn-light {
            background: white;
            color: #333;
            border: none;
            padding: 15px 40px;
            font-weight: 600;
            border-radius: 50px;
            transition: all 0.3s ease;
            -webkit-tap-highlight-color: transparent;
        }
        
        .cta-section .btn-light:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(255,255,255,0.3);
        }
        
        .cta-section .btn-light:active {
            transform: scale(0.95);
        }
        
        /* ===== MOBILE RESPONSIVE OPTIMIZATIONS ===== */
        
        /* Extra small devices (phones, 576px and down) */
        @media (max-width: 576px) {
            .page-hero {
                padding: 100px 0 60px;
            }
            
            .page-hero h1 {
                font-size: 2.2rem !important;
            }
            
            .page-hero p {
                font-size: 1rem !important;
                padding: 0 15px;
            }
            
            .services-grid {
                grid-template-columns: 1fr;
                gap: 20px;
                margin: 30px 0;
            }
            
            .service-card {
                margin-bottom: 0;
            }
            
            .service-image {
                height: 200px;
            }
            
            .service-content {
                padding: 20px;
            }
            
            .service-content h3 {
                font-size: 1.3rem !important;
            }
            
            .service-content p {
                font-size: 0.95rem !important;
                margin-bottom: 15px;
            }
            
            .service-btn {
                padding: 10px 25px !important;
                font-size: 0.95rem !important;
                width: 100%;
                text-align: center;
            }
            
            .service-overlay span {
                font-size: 1rem !important;
                padding: 10px 20px !important;
            }
            
            .stats-section {
                padding: 40px 0;
            }
            
            .stat-item {
                padding: 20px;
            }
            
            .stat-number {
                font-size: 2.2rem !important;
            }
            
            .stat-label {
                font-size: 0.95rem !important;
            }
            
            .cta-section {
                padding: 60px 0 !important;
            }
            
            .cta-section h2 {
                font-size: 1.8rem !important;
            }
            
            .cta-section p {
                font-size: 1rem !important;
            }
            
            .cta-section .btn-light {
                padding: 12px 30px !important;
                font-size: 1rem !important;
                width: 100%;
                max-width: 280px;
            }
        }
        
        /* Small devices (landscape phones, 577px to 767px) */
        @media (min-width: 577px) and (max-width: 767px) {
            .page-hero h1 {
                font-size: 2.8rem !important;
            }
            
            .services-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 20px;
            }
            
            .service-image {
                height: 180px;
            }
            
            .service-content h3 {
                font-size: 1.2rem !important;
            }
            
            .service-content p {
                font-size: 0.9rem !important;
            }
            
            .service-btn {
                padding: 8px 20px !important;
                font-size: 0.9rem !important;
                width: 100%;
            }
            
            .stat-number {
                font-size: 2.2rem !important;
            }
            
            .cta-section h2 {
                font-size: 2rem !important;
            }
        }
        
        /* Medium devices (tablets, 768px to 991px) */
        @media (min-width: 768px) and (max-width: 991px) {
            .services-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .service-image {
                height: 200px;
            }
        }
        
        /* Touch target optimization for mobile */
        @media (max-width: 768px) {
            .service-btn,
            .cta-section .btn-light {
                min-height: 44px;
                display: flex;
                align-items: center;
                justify-content: center;
            }
            
            /* Remove hover effects on mobile */
            .service-card:hover {
                transform: none;
            }
            
            .service-card:active {
                transform: scale(0.98);
            }
            
            .service-overlay {
                display: none; /* Hide overlay on mobile, use button instead */
            }
            
            /* Improve spacing */
            .container {
                padding-left: 20px;
                padding-right: 20px;
            }
            
            /* Fix any horizontal scrolling */
            body {
                overflow-x: hidden;
                width: 100%;
            }
            
            /* Better grid for stats on mobile */
            .row.g-4 {
                --bs-gutter-y: 1rem;
            }
        }
        
        /* Fix for notched phones */
        @supports (padding: max(0px)) {
            .container {
                padding-left: max(20px, env(safe-area-inset-left));
                padding-right: max(20px, env(safe-area-inset-right));
            }
        }
        
        /* Reduced motion preferences */
        @media (prefers-reduced-motion: reduce) {
            .service-card,
            .service-image img,
            .service-overlay,
            .service-btn,
            .stat-item,
            .cta-section::before {
                animation: none;
                transition: none;
            }
        }
    </style>
</head>
<body>
    <%- include('partials/header'); %>
    <%- include('partials/floating-buttons'); %>

    <!-- Hero Section -->
    <section class="page-hero">
        <div class="container text-center">
            <h1 data-aos="fade-up">Our Services</h1>
            <p class="lead" data-aos="fade-up" data-aos-delay="100">Comprehensive technology solutions tailored to your business needs</p>
        </div>
    </section>

    <!-- Services Grid -->
    <section class="py-5">
        <div class="container">
            <div class="services-grid">
                <!-- Renewable Energy -->
                <div class="service-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="service-image">
                        <img src="/images/solar_installers.webp" alt="Renewable Energy" loading="lazy">
                        <!-- Make the entire overlay a clickable link (hidden on mobile) -->
                        <a href="/services/renewable-energy" class="service-overlay-link">
                            <div class="service-overlay">
                                <span>View Details</span>
                            </div>
                        </a>
                    </div>
                    <div class="service-content">
                        <h3>Renewable Energy & Solar</h3>
                        <p>Harness the power of the sun with our cutting-edge solar technology. Reduce energy costs and your carbon footprint.</p>
                        <a href="/services/renewable-energy" class="service-btn">Learn More</a>
                    </div>
                </div>

                <!-- Network Infrastructure -->
                <div class="service-card" data-aos="fade-up" data-aos-delay="200">
                    <div class="service-image">
                        <img src="/images/Networking BANNER 1.webp" alt="Network Infrastructure" loading="lazy">
                        <a href="/services/network-infrastructure" class="service-overlay-link">
                            <div class="service-overlay">
                                <span>View Details</span>
                            </div>
                        </a>
                    </div>
                    <div class="service-content">
                        <h3>Network Infrastructure</h3>
                        <p>Build robust, scalable, and secure network foundation for your business with enterprise-grade solutions.</p>
                        <a href="/services/network-infrastructure" class="service-btn">Learn More</a>
                    </div>
                </div>

                <!-- ISP & Internet -->
                <div class="service-card" data-aos="fade-up" data-aos-delay="300">
                    <div class="service-image">
                        <img src="/images/fiber-cables-1200x675.webp" alt="ISP Services" loading="lazy">
                        <a href="/services/isp-internet" class="service-overlay-link">
                            <div class="service-overlay">
                                <span>View Details</span>
                            </div>
                        </a>
                    </div>
                    <div class="service-content">
                        <h3>ISP & Internet Services</h3>
                        <p>Lightning-fast, reliable internet connectivity for businesses and homes with 99.9% uptime guarantee.</p>
                        <a href="/services/isp-internet" class="service-btn">Learn More</a>
                    </div>
                </div>

                <!-- CCTV & Security -->
                <div class="service-card" data-aos="fade-up" data-aos-delay="400">
                    <div class="service-image">
                        <img src="/images/CCTV Banner 1.webp" alt="Security Systems" loading="lazy">
                        <a href="/services/cctv-security" class="service-overlay-link">
                            <div class="service-overlay">
                                <span>View Details</span>
                            </div>
                        </a>
                    </div>
                    <div class="service-content">
                        <h3>CCTV & Security Systems</h3>
                        <p>Advanced surveillance solutions to protect what matters most with intelligent analytics and 24/7 monitoring.</p>
                        <a href="/services/cctv-security" class="service-btn">Learn More</a>
                    </div>
                </div>

                <!-- Software Development -->
                <div class="service-card" data-aos="fade-up" data-aos-delay="500">
                    <div class="service-image">
                        <img src="/images/website-development-process-full-guide-1-fb.webp" alt="Software Development" loading="lazy">
                        <a href="/services/software-development" class="service-overlay-link">
                            <div class="service-overlay">
                                <span>View Details</span>
                            </div>
                        </a>
                    </div>
                    <div class="service-content">
                        <h3>Software Development</h3>
                        <p>Custom software solutions that drive business growth, from web applications to enterprise systems.</p>
                        <a href="/services/software-development" class="service-btn">Learn More</a>
                    </div>
                </div>

                <!-- IT Consulting -->
                <div class="service-card" data-aos="fade-up" data-aos-delay="600">
                    <div class="service-image">
                        <img src="/images/Consultant Banner 1.webp" alt="IT Consulting" loading="lazy">
                        <a href="/services/it-consulting" class="service-overlay-link">
                            <div class="service-overlay">
                                <span>View Details</span>
                            </div>
                        </a>
                    </div>
                    <div class="service-content">
                        <h3>IT Consulting & Procurement</h3>
                        <p>Strategic technology consulting to optimize your IT investments and digital transformation journey.</p>
                        <a href="/services/it-consulting" class="service-btn">Learn More</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="container">
            <div class="row g-4">
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="100">
                    <div class="stat-item">
                        <div class="stat-number">500+</div>
                        <div class="stat-label">Projects Delivered</div>
                    </div>
                </div>
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="200">
                    <div class="stat-item">
                        <div class="stat-number">50+</div>
                        <div class="stat-label">Team Experts</div>
                    </div>
                </div>
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="300">
                    <div class="stat-item">
                        <div class="stat-number">9</div>
                        <div class="stat-label">Countries Served</div>
                    </div>
                </div>
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="400">
                    <div class="stat-item">
                        <div class="stat-number">24/7</div>
                        <div class="stat-label">Support Available</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container position-relative">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8">
                    <h2 data-aos="fade-up">Need a Custom Solution?</h2>
                    <p class="lead mb-5" data-aos="fade-up" data-aos-delay="100">Let's discuss your specific requirements and find the perfect solution for your business.</p>
                    <a href="/contact" class="btn btn-light btn-lg px-5 py-3" data-aos="fade-up" data-aos-delay="200">
                        <i class="bi bi-chat-dots me-2"></i>Get in Touch
                    </a>
                </div>
            </div>
        </div>
    </section>

    <%- include('partials/footer'); %>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="/js/animations.js"></script>
    <script src="/js/transitions.js"></script>
    <script>
        AOS.init({
            duration: 1000,
            once: true,
            offset: 100
        });
    </script>
</body>
</html>