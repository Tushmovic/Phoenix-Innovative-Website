<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
    <style>
        /* ===== HERO SECTION WITH ANIMATION ===== */
        .privacy-hero {
            background: linear-gradient(135deg, #0B132B, #1C2541, #3A506B);
            color: white;
            padding: 150px 0 100px;
            position: relative;
            overflow: hidden;
            margin-bottom: 0;
        }
        
        .privacy-hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,107,53,0.2) 0%, transparent 60%);
            animation: rotate 30s linear infinite;
        }
        
        .privacy-hero::after {
            content: '';
            position: absolute;
            bottom: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(67,97,238,0.15) 0%, transparent 60%);
            animation: rotate 40s linear infinite reverse;
        }
        
        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        .privacy-hero h1 {
            color: white;
            font-size: 4rem;
            font-weight: 800;
            margin-bottom: 20px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            position: relative;
            z-index: 2;
            animation: fadeInDown 1s ease;
        }
        
        .privacy-hero p {
            color: rgba(255,255,255,0.95);
            font-size: 1.3rem;
            position: relative;
            z-index: 2;
            animation: fadeInUp 1s ease 0.2s both;
        }
        
        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* ===== MAIN CONTENT SECTION ===== */
        .privacy-content {
            padding: 80px 0;
            background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
            position: relative;
        }
        
        .privacy-card {
            background: white;
            border-radius: 30px;
            padding: 60px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.1);
            transition: all 0.4s ease;
            border: 1px solid rgba(255,107,53,0.1);
            position: relative;
            overflow: hidden;
        }
        
        .privacy-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: linear-gradient(90deg, #FF6B35, #4361EE, #2EC4B6);
            transform: translateX(-100%);
            animation: slideBorder 1.5s ease 0.5s forwards;
        }
        
        @keyframes slideBorder {
            to { transform: translateX(0); }
        }
        
        .privacy-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 40px 80px rgba(255,107,53,0.15);
        }
        
        /* Last Updated */
        .last-updated {
            color: #666;
            font-style: italic;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 2px dashed #e0e0e0;
            font-size: 1.1rem;
        }
        
        /* Headings */
        .privacy-content h2 {
            color: #FF6B35;
            font-size: 2.2rem;
            font-weight: 700;
            margin: 50px 0 25px;
            position: relative;
            padding-left: 20px;
            transition: all 0.3s ease;
        }
        
        .privacy-content h2:first-of-type {
            margin-top: 0;
        }
        
        .privacy-content h2::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 5px;
            background: linear-gradient(180deg, #FF6B35, #4361EE);
            border-radius: 5px;
            transition: all 0.3s ease;
        }
        
        .privacy-content h2:hover {
            transform: translateX(10px);
        }
        
        .privacy-content h2:hover::before {
            width: 8px;
        }
        
        .privacy-content h3 {
            color: #333;
            font-size: 1.5rem;
            font-weight: 600;
            margin: 30px 0 15px;
            transition: all 0.3s ease;
        }
        
        .privacy-content h3:hover {
            color: #FF6B35;
            transform: translateX(5px);
        }
        
        /* Paragraphs */
        .privacy-content p {
            color: #444;
            line-height: 1.9;
            margin-bottom: 20px;
            font-size: 1.1rem;
        }
        
        /* Lists */
        .privacy-content ul {
            margin-bottom: 30px;
            padding-left: 30px;
        }
        
        .privacy-content li {
            color: #444;
            line-height: 1.8;
            margin-bottom: 12px;
            font-size: 1.05rem;
            position: relative;
            padding-left: 25px;
            list-style: none;
        }
        
        .privacy-content li::before {
            content: '•';
            color: #FF6B35;
            font-size: 1.5rem;
            position: absolute;
            left: 0;
            top: -5px;
            transition: all 0.3s ease;
        }
        
        .privacy-content li:hover::before {
            transform: scale(1.3);
            color: #4361EE;
        }
        
        /* Highlight Box */
        .highlight-box {
            background: linear-gradient(135deg, #fff5f0, #ffffff);
            padding: 35px;
            border-radius: 20px;
            border-left: 5px solid #FF6B35;
            margin: 40px 0;
            box-shadow: 0 10px 30px rgba(255,107,53,0.1);
            transition: all 0.4s ease;
            animation: pulse 2s infinite;
        }
        
        .highlight-box:hover {
            transform: scale(1.02);
            box-shadow: 0 15px 40px rgba(255,107,53,0.2);
        }
        
        @keyframes pulse {
            0%, 100% { box-shadow: 0 10px 30px rgba(255,107,53,0.1); }
            50% { box-shadow: 0 15px 40px rgba(255,107,53,0.15); }
        }
        
        .highlight-box p {
            margin-bottom: 0;
            font-size: 1.15rem;
        }
        
        .highlight-box strong {
            color: #FF6B35;
            font-size: 1.2rem;
        }
        
        /* Contact Links */
        .contact-list {
            background: linear-gradient(135deg, #f8f9fa, #ffffff);
            padding: 30px;
            border-radius: 20px;
            margin-top: 30px;
        }
        
        .contact-list li {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 10px 0;
            border-bottom: 1px solid #eee;
        }
        
        .contact-list li:last-child {
            border-bottom: none;
        }
        
        .contact-list i {
            font-size: 1.3rem;
            color: #FF6B35;
            width: 30px;
            transition: all 0.3s ease;
        }
        
        .contact-list li:hover i {
            transform: scale(1.2) rotate(10deg);
            color: #4361EE;
        }
        
        .contact-list a {
            color: #444;
            text-decoration: none;
            transition: all 0.3s ease;
        }
        
        .contact-list a:hover {
            color: #FF6B35;
            transform: translateX(5px);
        }
        
        /* Back to Top Button */
        .back-to-top {
            position: fixed;
            bottom: 100px;
            right: 30px;
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            opacity: 0;
            visibility: hidden;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            z-index: 100;
            box-shadow: 0 5px 20px rgba(255,107,53,0.3);
            border: 2px solid white;
        }
        
        .back-to-top.visible {
            opacity: 1;
            visibility: visible;
        }
        
        .back-to-top:hover {
            transform: translateY(-10px) scale(1.1);
            box-shadow: 0 15px 30px rgba(255,107,53,0.4);
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .privacy-hero h1 {
                font-size: 2.5rem;
            }
            
            .privacy-card {
                padding: 30px 20px;
            }
            
            .privacy-content h2 {
                font-size: 1.8rem;
            }
            
            .privacy-content h3 {
                font-size: 1.3rem;
            }
            
            .privacy-content p,
            .privacy-content li {
                font-size: 1rem;
            }
            
            .back-to-top {
                bottom: 80px;
                right: 15px;
                width: 45px;
                height: 45px;
                font-size: 1.3rem;
            }
        }
    </style>
</head>
<body>
    <%- include('partials/header'); %>
    <%- include('partials/floating-buttons'); %>
    
    <!-- Hero Section with Animation -->
    <section class="privacy-hero">
        <div class="container text-center">
            <h1 class="reveal-text">Privacy Policy</h1>
            <p>Last Updated: February 2026</p>
        </div>
    </section>
    
    <!-- Main Content Section -->
    <section class="privacy-content">
        <div class="container">
            <div class="row">
                <div class="col-lg-10 mx-auto">
                    <div class="privacy-card" data-aos="fade-up" data-aos-duration="1000">
                        <p class="last-updated">Effective Date: February 27, 2026</p>
                        
                        <h2 data-aos="fade-right">Introduction</h2>
                        <p data-aos="fade-up" data-aos-delay="100">Phoenix Innovative Technologies Ltd ("we," "our," or "us") respects your privacy and is committed to protecting your personal data. This privacy policy explains how we collect, use, disclose, and safeguard your information when you visit our website or use our services.</p>
                        
                        <div class="highlight-box" data-aos="zoom-in" data-aos-delay="200">
                            <p><strong>Our Commitment:</strong> We will never sell your personal information to third parties. Your trust is our most valuable asset.</p>
                        </div>
                        
                        <h2 data-aos="fade-right" data-aos-delay="100">Information We Collect</h2>
                        
                        <h3 data-aos="fade-right" data-aos-delay="150">Personal Data</h3>
                        <p data-aos="fade-up" data-aos-delay="200">While using our website, we may ask you to provide certain personally identifiable information including:</p>
                        <ul data-aos="fade-up" data-aos-delay="250">
                            <li>Name and contact information (email address, phone number)</li>
                            <li>Company name and business details</li>
                            <li>Information provided through contact forms</li>
                            <li>Chatbot conversation data</li>
                        </ul>
                        
                        <h3 data-aos="fade-right" data-aos-delay="300">Usage Data</h3>
                        <p data-aos="fade-up" data-aos-delay="350">We automatically collect information about how you interact with our website, including:</p>
                        <ul data-aos="fade-up" data-aos-delay="400">
                            <li>IP address and browser type</li>
                            <li>Pages visited and time spent</li>
                            <li>Referring website addresses</li>
                            <li>Device information</li>
                        </ul>
                        
                        <h3 data-aos="fade-right" data-aos-delay="450">Cookies and Tracking</h3>
                        <p data-aos="fade-up" data-aos-delay="500">We use cookies and similar tracking technologies to monitor activity on our website and store certain information. You can instruct your browser to refuse all cookies or to indicate when a cookie is being sent.</p>
                        
                        <h2 data-aos="fade-right" data-aos-delay="100">How We Use Your Information</h2>
                        <p data-aos="fade-up" data-aos-delay="150">We use the collected information for various purposes:</p>
                        <ul data-aos="fade-up" data-aos-delay="200">
                            <li>To provide and maintain our services</li>
                            <li>To respond to your inquiries and questions</li>
                            <li>To send you technical notices and support messages</li>
                            <li>To improve our website and services</li>
                            <li>To monitor usage and detect technical issues</li>
                            <li>To comply with legal obligations</li>
                        </ul>
                        
                        <h2 data-aos="fade-right" data-aos-delay="100">Sharing Your Information</h2>
                        <p data-aos="fade-up" data-aos-delay="150">We do not sell or rent your personal information to third parties. We may share information with:</p>
                        <ul data-aos="fade-up" data-aos-delay="200">
                            <li>Service providers who assist in operating our website</li>
                            <li>Legal authorities when required by law</li>
                            <li>Business partners with your consent</li>
                        </ul>
                        
                        <h2 data-aos="fade-right" data-aos-delay="100">Data Security</h2>
                        <p data-aos="fade-up" data-aos-delay="150">We implement appropriate technical and organizational security measures to protect your personal data. However, no method of transmission over the Internet is 100% secure, and we cannot guarantee absolute security.</p>
                        
                        <div class="highlight-box" data-aos="zoom-in" data-aos-delay="200">
                            <p><strong>Security Measures:</strong> SSL/TLS encryption, regular security audits, restricted data access, and secure data storage protocols.</p>
                        </div>
                        
                        <h2 data-aos="fade-right" data-aos-delay="100">Your Rights</h2>
                        <p data-aos="fade-up" data-aos-delay="150">Depending on your location, you may have the right to:</p>
                        <ul data-aos="fade-up" data-aos-delay="200">
                            <li>Access your personal information</li>
                            <li>Correct inaccurate data</li>
                            <li>Request deletion of your data</li>
                            <li>Object to data processing</li>
                            <li>Data portability</li>
                        </ul>
                        <p data-aos="fade-up" data-aos-delay="250">To exercise any of these rights, please contact us at <a href="mailto:phoenixinnovative2025@gmail.com" style="color: #FF6B35; text-decoration: none;">phoenixinnovative2025@gmail.com</a>.</p>
                        
                        <h2 data-aos="fade-right" data-aos-delay="100">Third-Party Links</h2>
                        <p data-aos="fade-up" data-aos-delay="150">Our website may contain links to external sites. We are not responsible for the privacy practices or content of these sites.</p>
                        
                        <h2 data-aos="fade-right" data-aos-delay="100">Children's Privacy</h2>
                        <p data-aos="fade-up" data-aos-delay="150">Our website is not intended for children under 13. We do not knowingly collect information from children.</p>
                        
                        <h2 data-aos="fade-right" data-aos-delay="100">International Data Transfers</h2>
                        <p data-aos="fade-up" data-aos-delay="150">Your information may be transferred to and maintained on computers located outside of your state, province, country, or other governmental jurisdiction where the data protection laws may differ. If you are located outside Nigeria and choose to provide information to us, please note that we transfer the data to Nigeria and process it there.</p>
                        
                        <h2 data-aos="fade-right" data-aos-delay="100">Changes to This Policy</h2>
                        <p data-aos="fade-up" data-aos-delay="150">We may update this privacy policy periodically. We will notify you of changes by posting the new policy on this page with an updated effective date.</p>
                        
                        <h2 data-aos="fade-right" data-aos-delay="100">Contact Us</h2>
                        <p data-aos="fade-up" data-aos-delay="150">If you have questions about this privacy policy, please contact us:</p>
                        <ul class="contact-list" data-aos="fade-up" data-aos-delay="200">
                            <li>
                                <i class="bi bi-envelope-fill"></i>
                                <a href="mailto:phoenixinnovative2025@gmail.com">phoenixinnovative2025@gmail.com</a>
                            </li>
                            <li>
                                <i class="bi bi-telephone-fill"></i>
                                <a href="tel:+2349135926075">+234 913 592 6075</a>
                            </li>
                            <li>
                                <i class="bi bi-whatsapp"></i>
                                <a href="https://wa.me/2349135926075" target="_blank">+234 913 592 6075 (WhatsApp)</a>
                            </li>
                            <li>
                                <i class="bi bi-geo-alt-fill"></i>
                                <span>Abuja, Nigeria</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Back to Top Button -->
    <div class="back-to-top" id="backToTop">
        <i class="bi bi-arrow-up"></i>
    </div>
    
    <%- include('partials/footer'); %>
    
    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // Initialize AOS
        AOS.init({
            duration: 1000,
            once: true,
            offset: 100,
            easing: 'ease-in-out'
        });
        
        // Back to top functionality
        const backToTop = document.getElementById('backToTop');
        
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
                backToTop.classList.add('visible');
            } else {
                backToTop.classList.remove('visible');
            }
        });
        
        backToTop.addEventListener('click', () => {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        });
        
        // Add floating animation to elements
        document.querySelectorAll('.privacy-content h2, .privacy-content h3').forEach(el => {
            el.addEventListener('mouseenter', function() {
                this.style.transition = 'all 0.3s ease';
            });
        });
    </script>
</body>
</html>