<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
    <style>
        .error-container {
            min-height: 60vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 80px 20px;
        }
        
        .error-card {
            background: white;
            border-radius: 30px;
            padding: 50px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            max-width: 600px;
            margin: 0 auto;
        }
        
        .error-icon {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 30px;
            color: white;
            font-size: 3rem;
        }
        
        .error-card h1 {
            color: #333;
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 20px;
        }
        
        .error-card p {
            color: #666;
            font-size: 1.2rem;
            margin-bottom: 30px;
        }
        
        .btn-home {
            display: inline-block;
            padding: 15px 40px;
            background: linear-gradient(135deg, #FF6B35, #F25F3A);
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        
        .btn-home:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(255,107,53,0.3);
        }
    </style>
</head>
<body>
    <%- include('partials/header'); %>
    <%- include('partials/floating-buttons'); %>
    
    <div class="error-container">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto">
                    <div class="error-card">
                        <div class="error-icon">
                            <i class="bi bi-question-circle"></i>
                        </div>
                        <h1>404 - Page Not Found</h1>
                        <p>The page you're looking for doesn't exist or has been moved.</p>
                        <a href="/" class="btn-home">
                            <i class="bi bi-house-door me-2"></i>Return Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <%- include('partials/footer'); %>
</body>
</html>